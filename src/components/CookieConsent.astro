---
// Cookie consent banner — pairs with Google Consent Mode v2.
//
// The consent DEFAULT (everything ad/analytics denied) is set in BaseLayout's <head> BEFORE the
// GTM snippet, so no measurement cookie is written until the visitor accepts. This component
// renders the banner and, on a choice, calls gtag('consent','update',…) + persists the decision
// in localStorage. Returning visitors are read back in the head default (no flash, no re-prompt).
//
// Zero framework: native <button>s + one module script. Reuses the site .btn classes and tokens,
// so there is no redesign. Links to the existing /legal/cookies policy.
---
<section id="cookie-consent" class="cc" role="region" aria-label="Cookie consent" hidden>
  <div class="cc-inner">
    <div class="cc-copy">
      <p class="cc-title">Cookies</p>
      <p class="cc-desc">
        We use cookies to measure how the site is used so we can improve it. Analytics and
        marketing cookies stay off until you accept. See our <a href="/legal/cookies">cookie policy</a>.
      </p>
    </div>
    <div class="cc-actions">
      <button type="button" class="btn btn-o" data-consent="denied">Reject</button>
      <button type="button" class="btn btn-p" data-consent="granted">Accept</button>
    </div>
  </div>
</section>

<style>
  .cc {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 200; /* above the sticky header (50) and dropdowns */
    background: var(--surface);
    border-top: 1px solid var(--line);
    box-shadow: var(--shadow);
  }
  .cc[hidden] { display: none; }
  /* Reveal plays automatically when the banner is shown (the [hidden] attribute is removed).
     The base state is fully visible, so the banner can never get stuck invisible — no JS class
     toggle and no requestAnimationFrame, which can be throttled in background/headless contexts. */
  .cc:not([hidden]) { animation: cc-in 0.28s var(--ease); }
  @keyframes cc-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: none; }
  }
  .cc-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 28px;
    flex-wrap: wrap;
  }
  .cc-copy { max-width: 760px; }
  .cc-title {
    font-family: var(--fm);
    text-transform: uppercase;
    letter-spacing: 0.09em;
    font-size: 11px;
    color: var(--muted);
    margin: 0 0 4px;
  }
  .cc-desc {
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
  }
  .cc-desc a { color: var(--violet-700); text-decoration: underline; }
  .cc-actions { display: flex; gap: 12px; flex-shrink: 0; }
  @media (max-width: 600px) {
    .cc-inner { padding: 14px 16px; gap: 14px; }
    .cc-actions { width: 100%; }
    .cc-actions .btn { flex: 1; justify-content: center; }
  }
  @media (prefers-reduced-motion: reduce) {
    .cc:not([hidden]) { animation: none; }
  }
</style>

<script>
  const KEY = 'zicy-consent';
  const banner = document.getElementById('cookie-consent');

  function gtag() {
    (window.dataLayer = window.dataLayer || []).push(arguments);
  }

  function apply(choice: string) {
    const v = choice === 'granted' ? 'granted' : 'denied';
    gtag('consent', 'update', {
      ad_storage: v,
      ad_user_data: v,
      ad_personalization: v,
      analytics_storage: v,
    });
    // Surface the decision to GTM so triggers can react if needed.
    (window.dataLayer = window.dataLayer || []).push({
      event: v === 'granted' ? 'consent_granted' : 'consent_denied',
    });
  }

  function show() {
    if (banner) banner.hidden = false;
  }

  function hide() {
    if (banner) banner.hidden = true;
  }

  function setChoice(choice: string) {
    try {
      localStorage.setItem(KEY, choice);
    } catch (e) {
      /* private mode — choice applies for the session only */
    }
    apply(choice);
    hide();
  }

  // Only prompt if there is no stored decision yet.
  let stored: string | null = null;
  try {
    stored = localStorage.getItem(KEY);
  } catch (e) {
    /* ignore */
  }
  if (stored !== 'granted' && stored !== 'denied') {
    show();
  }

  banner?.querySelectorAll<HTMLButtonElement>('[data-consent]').forEach((b) => {
    b.addEventListener('click', () => setChoice(b.dataset.consent || 'denied'));
  });

  // Footer "Cookie settings" link reopens the banner so consent can be changed/withdrawn
  // as easily as it was given (GDPR). Exposed globally too, for any other entry point.
  (window as any).zicyOpenCookieSettings = show;
  document.getElementById('cookie-settings')?.addEventListener('click', (e) => {
    e.preventDefault();
    show();
  });
</script>
