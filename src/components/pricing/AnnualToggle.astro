---
// Monthly / annual switch. Sets data-billing on the tier grid (id from the `target` prop); CSS in
// CoreTiers swaps which price each card shows. Labels and the note come from pricing.ts.
import { ANNUAL } from '../../data/pricing';

interface Props {
  /** id of the element whose data-billing attribute this toggle drives. */
  target: string;
}
const { target } = Astro.props;
const toggleId = `${target}-billing-toggle`;
---
<div class="atoggle" role="group" aria-label="Billing period">
  <span class:list={['atoggle-side', 'is-monthly']}>{ANNUAL.labels.monthly}</span>
  <label class="atoggle-switch">
    <input type="checkbox" id={toggleId} data-annual-toggle data-target={target} />
    <span class="atoggle-track" aria-hidden="true"><span class="atoggle-thumb"></span></span>
    <span class="visually-hidden">Show annual pricing</span>
  </label>
  <span class:list={['atoggle-side', 'is-annual']}>{ANNUAL.labels.annual}</span>
  <span class="atoggle-note">{ANNUAL.note}</span>
</div>

<script>
  // One listener per toggle on the page; drives the grid named by data-target.
  document.querySelectorAll('[data-annual-toggle]').forEach((el) => {
    const input = el as HTMLInputElement;
    const grid = document.getElementById(input.dataset.target || '');
    if (!grid) return;
    const sync = () => { grid.dataset.billing = input.checked ? 'annual' : 'monthly'; };
    input.addEventListener('change', sync);
    sync();
  });
</script>

<style>
  .atoggle{display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap}
  .atoggle-side{font-family:var(--fm);font-size:13px;color:var(--muted);letter-spacing:.02em}
  .atoggle-switch{position:relative;display:inline-flex;align-items:center;cursor:pointer}
  .atoggle-switch input{position:absolute;opacity:0;width:100%;height:100%;margin:0;cursor:pointer}
  .atoggle-track{width:44px;height:24px;border-radius:var(--r-pill);background:var(--mist);border:1px solid var(--line);transition:background .18s var(--ease),border-color .18s var(--ease);display:inline-block;position:relative}
  .atoggle-thumb{position:absolute;top:2px;left:2px;width:18px;height:18px;border-radius:50%;background:#fff;box-shadow:0 1px 3px rgba(21,19,42,.2);transition:transform .18s var(--ease)}
  .atoggle-switch input:checked + .atoggle-track{background:var(--violet);border-color:var(--violet)}
  .atoggle-switch input:checked + .atoggle-track .atoggle-thumb{transform:translateX(20px)}
  .atoggle-switch input:focus-visible + .atoggle-track{outline:2px solid var(--violet);outline-offset:2px}
  .atoggle-note{font-family:var(--fm);font-size:12px;color:var(--violet-700);background:var(--violet-50);padding:4px 11px;border-radius:var(--r-pill)}
  .visually-hidden{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;border:0}
</style>
