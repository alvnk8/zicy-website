---
// Competitor comparison. Zicy is column 0 and is visually emphasised. Rows and columns render
// exactly from COMPARISON_ROWS / COMPARISON_COLUMNS; the dated footnote is required before go-live.
import { COMPARISON_COLUMNS, COMPARISON_ROWS, COMPARISON_FOOTNOTE } from '../../data/pricing';
---
<section class="reveal" id="comparison">
  <div class="wrap">
    <div class="shead" style="max-width:none;text-align:center;margin-bottom:28px">
      <span class="eyebrow" style="justify-content:center"><span class="ix">05</span> Compare</span>
      <h2 style="margin-top:14px">All five engines, no add-on maths.</h2>
    </div>

    <div class="cmp-scroll">
      <table class="cmp">
        <thead>
          <tr>
            <th scope="col" class="cmp-rowhead"><span class="visually-hidden">Feature</span></th>
            {COMPARISON_COLUMNS.map((col, i) => (
              <th scope="col" class:list={['cmp-col', { 'is-zicy': i === 0 }]}>{col}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {COMPARISON_ROWS.map((row) => (
            <tr>
              <th scope="row" class="cmp-rowhead">{row.feature}</th>
              {row.values.map((v, i) => (
                <td class:list={['cmp-cell', { 'is-zicy': i === 0 }]}>{v}</td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="cmp-foot mono">{COMPARISON_FOOTNOTE}</p>
  </div>
</section>

<style>
  .cmp-scroll{overflow-x:auto;-webkit-overflow-scrolling:touch;border:1px solid var(--line);border-radius:var(--r-lg);background:var(--surface)}
  .cmp{border-collapse:collapse;width:100%;min-width:820px;font-size:13.5px}
  .cmp th,.cmp td{padding:12px 14px;text-align:left;border-bottom:1px solid var(--line);vertical-align:top}
  .cmp thead th{font-family:var(--fm);font-size:12px;font-weight:500;letter-spacing:.03em;color:var(--ink-2);background:var(--paper)}
  .cmp-rowhead{font-family:var(--fs);font-weight:500;color:var(--ink);position:sticky;left:0;background:var(--surface);z-index:1;min-width:220px}
  .cmp thead .cmp-rowhead{background:var(--paper)}
  .cmp-cell{color:var(--ink-2)}
  /* Zicy column emphasis: violet wash, ink text, medium weight, top+side accent. */
  .cmp .is-zicy{background:var(--violet-50);color:var(--ink);font-weight:500;box-shadow:inset 1px 0 0 var(--violet-300),inset -1px 0 0 var(--violet-300)}
  .cmp thead .is-zicy{color:var(--violet-700);background:var(--violet-100)}
  .cmp tbody tr:last-child td,.cmp tbody tr:last-child th{border-bottom:0}
  .cmp-foot{margin:16px 0 0;font-size:12px;color:var(--muted);text-align:center}
  .visually-hidden{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;border:0}
</style>
