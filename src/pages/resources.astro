---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../data/site';
import { RESOURCE_POSTS } from '../data/resources-posts';

const title = 'Zicy resources, AI visibility guides, research and updates';
const description =
  'Practical guides to AEO/GEO, original research, and updates on how AI search is changing brand discovery.';

// Drift guard: the post listing and the Blog node's blogPost members are generated from
// RESOURCE_POSTS. Assert at build time that RESOURCE_POSTS matches the actual post files under
// src/pages/resources/*.astro, so the two can never silently diverge. import.meta.glob is a
// single-level glob, so it matches the 19 post pages but not the glossary subdirectory.
const fileSlugs = Object.keys(import.meta.glob('./resources/*.astro'))
  .map((p) => p.split('/').pop()!.replace(/\.astro$/, ''))
  .sort();
const dataSlugs = RESOURCE_POSTS.map((p) => p.slug).sort();
if (JSON.stringify(fileSlugs) !== JSON.stringify(dataSlugs)) {
  throw new Error(
    `resources-posts.ts is out of sync with src/pages/resources/*.astro.\n  files: ${fileSlugs.join(', ')}\n  data:  ${dataSlugs.join(', ')}`
  );
}

// Blog node with members. blogPost references every live post by its BlogPosting @id, generated
// from RESOURCE_POSTS (one entry per live post), so it cannot drift.
const blog = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  // #blog fragment on the /resources URL: disambiguates the Blog collection
  // from the page itself, and is the stable @id the migrated posts reference.
  '@id': `${SITE.url}/resources#blog`,
  name: 'Zicy resources',
  description,
  url: `${SITE.url}/resources`,
  publisher: { '@id': `${SITE.url}/#org` },
  inLanguage: 'en',
  blogPost: RESOURCE_POSTS.map((p) => ({ '@id': `${SITE.url}/resources/${p.slug}#article` })),
};

// The three pillars already on the page; cards are grouped under these by articleSection.
const PILLARS = [
  { section: 'Guides' as const, blurb: 'AEO and GEO fundamentals: schema, citations, prompts, the practical playbooks.' },
  { section: 'Research' as const, blurb: 'Zicy\'s own analysis of how AI cites and describes brands across engines and markets.' },
  { section: 'Updates' as const, blurb: 'Platform changes, policy shifts, and what they mean for your brand.' },
];

const MONTHS = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
function fmtDate(iso: string): string {
  const [y, m, d] = iso.split('-').map(Number);
  return `${d} ${MONTHS[m - 1]} ${y}`;
}
const postsIn = (section: string) => RESOURCE_POSTS.filter((p) => p.articleSection === section);
---
<BaseLayout title={title} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(blog)} />

  <section class="hero inner">
    <div class="wrap">
      <span class="eyebrow">Resources</span>
      <h1>How AI search is changing brand discovery.</h1>
      <p class="lead">Practical guides, original research, and plain-English explainers for marketing, PR and publishing teams.</p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="shead"><span class="eyebrow"><span class="ix">01</span> Three pillars</span><h2>Guides, research and updates.</h2></div>

      {PILLARS.map((pillar) => {
        const posts = postsIn(pillar.section);
        return (
          <div class="pillar">
            <div class="phead">
              <span class="eyebrow">{pillar.section}</span>
              <p class="muted" style="font-size:14px;margin-top:4px">{pillar.blurb}</p>
            </div>
            {posts.length > 0 ? (
              <div class="grid-3">
                {posts.map((p) => (
                  <article class="card pcard">
                    <h3><a href={`/resources/${p.slug}`}>{p.title}</a></h3>
                    <p class="pdesc">{p.description}</p>
                    <p class="pmeta">{p.authorName} &middot; {fmtDate(p.datePublished)}</p>
                  </article>
                ))}
              </div>
            ) : (
              <p class="muted" style="font-size:14px">New {pillar.section.toLowerCase()} will appear here soon.</p>
            )}
          </div>
        );
      })}
    </div>
  </section>

  <section style="background:var(--lavender)">
    <div class="wrap">
      <div class="shead"><span class="eyebrow"><span class="ix">02</span> Glossary</span><h2>The AI visibility glossary.</h2></div>
      <div style="max-width:760px">
        <p class="lead" style="font-size:18px">
          Canonical, plain-English definitions of the terms that describe AI visibility measurement:
          AI visibility, AEO and GEO, mention and citation coverage, AI share of voice, prompt
          tracking, entity gaps and more.
        </p>
        <div class="cta-row" style="margin-top:24px">
          <a class="btn btn-p" href="/resources/glossary">Open the glossary</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .pillar{margin-top:28px}
  .pillar + .pillar{margin-top:40px}
  .phead{margin-bottom:16px}
  .pcard{display:flex;flex-direction:column;gap:8px}
  .pcard h3{font-family:var(--display);font-size:18px;line-height:1.3;letter-spacing:-0.01em;margin:0}
  .pcard h3 a{color:var(--indigo)}
  .pcard h3 a:hover{color:var(--indigo-bright)}
  .pdesc{font-size:14.5px;color:#4a4960;line-height:1.55;margin:0}
  .pmeta{font-size:13px;color:var(--muted);margin:auto 0 0;font-family:var(--mono);letter-spacing:.02em}
</style>
