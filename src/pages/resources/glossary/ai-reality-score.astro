---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { SITE } from '../../../data/site';
import { AI_REALITY_SCORE, GLOSSARY_TERMS } from './_glossary-data';

// Short glossary summary. The canonical definition, methodology and FAQ live on
// /platform/ai-reality-score (owned by another page), so this page defers to it rather than
// duplicating the content, and is marked noindex to avoid competing with the canonical page.
const t = AI_REALITY_SCORE;
const url = `${SITE.url}/resources/glossary/${t.slug}`;
const canonical = `${SITE.url}${t.canonicalPath}`;

const title = 'AI Reality Score, AI visibility glossary';
const description = t.definition;

const LABELS: Record<string, string> = Object.fromEntries(GLOSSARY_TERMS.map((g) => [g.slug, g.term]));

// Only a BreadcrumbList here; the canonical DefinedTerm + FAQ live on the platform page.
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${url}#breadcrumb`,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Resources', item: `${SITE.url}/resources` },
    { '@type': 'ListItem', position: 3, name: 'Glossary', item: `${SITE.url}/resources/glossary` },
    { '@type': 'ListItem', position: 4, name: t.term, item: url },
  ],
};
---
<BaseLayout title={title} description={description} noindex={true}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumb)} />

  <section class="hero inner">
    <div class="wrap">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="sep" aria-hidden="true">&rsaquo;</span>
        <a href="/resources">Resources</a>
        <span class="sep" aria-hidden="true">&rsaquo;</span>
        <a href="/resources/glossary">Glossary</a>
        <span class="sep" aria-hidden="true">&rsaquo;</span>
        <span class="here" aria-current="page">{t.term}</span>
      </nav>
      <span class="eyebrow">AI visibility glossary</span>
      <h1>{t.term}</h1>
      <p class="def">{t.definition}</p>
    </div>
  </section>

  <section style="background:var(--mist)">
    <div class="wrap">
      <div style="max-width:760px">
        <p class="lead" style="font-size:18px">
          This is the glossary summary. The full definition, the measurement methodology, what pulls
          the score down and how to improve it live on the canonical AI Reality Score page.
        </p>
        <div class="cta-row" style="margin-top:24px">
          <a class="btn btn-p" href={t.canonicalPath}>Read the full AI Reality Score page</a>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow">Related terms</span>
        <h2>Keep reading.</h2>
      </div>
      <ul class="related">
        {t.related.map((slug) => (
          <li><a href={`/resources/glossary/${slug}`}>{LABELS[slug] ?? slug}</a></li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  /* Breadcrumb: tokens only, no hardcoded hex. */
  .crumbs{display:flex;flex-wrap:wrap;align-items:center;gap:8px;font-size:13px;color:var(--muted);margin-bottom:18px}
  .crumbs a{color:var(--muted)}
  .crumbs a:hover{color:var(--indigo)}
  .crumbs .sep{color:var(--line-2)}
  .crumbs .here{color:var(--ink)}

  .def{font-family:var(--display);font-size:clamp(20px,2.4vw,26px);line-height:1.45;color:var(--ink);max-width:820px;letter-spacing:-0.01em}

  .related{list-style:none;margin:0;padding:0;display:flex;flex-wrap:wrap;gap:10px}
  .related a{
    display:inline-block;padding:8px 14px;border:0.5px solid var(--line);border-radius:999px;
    background:#fff;font-size:14px;color:var(--indigo);font-weight:500;
  }
  .related a:hover{border-color:var(--indigo);color:var(--indigo-bright)}
</style>
