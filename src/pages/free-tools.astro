---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Zicy free tools — AEO/GEO Consultant & Chrome extension';
const description =
  'Two free ways to see how AI reads your brand: the AEO/GEO Consultant and a browser extension.';

const tools = [
  { eyebrow: 'AI consultant', h: 'AEO/GEO Consultant', p: 'Ask anything about AEO or GEO, or audit a page on the spot. Powered by Growth.pro’s proprietary framework.', link: 'Open the consultant →', href: '/aeo-geo-consultant' },
  { eyebrow: 'Chrome extension', h: 'Audit any page in your browser', p: 'Instant AI-readiness score, AI bot-access checker, and one-click schema generator. Free.', link: 'See the extension →', href: '/chrome-extension' },
];
---
<BaseLayout title={title} description={description}>
  <section class="hero inner">
    <div class="wrap">
      <span class="eyebrow">Free tools</span>
      <h1>Try Zicy before you commit.</h1>
      <p class="lead">Two free ways to see how AI reads your brand — an AI consultant and a browser extension.</p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="shead"><span class="eyebrow"><span class="ix">01</span> Pick a tool</span><h2>Two ways in.</h2></div>
      <div class="grid-2">
        {tools.map((t) => (
          <div class="card">
            <span class="eyebrow">{t.eyebrow}</span>
            <h3>{t.h}</h3>
            <p>{t.p}</p>
            <a class="link" href={t.href}>{t.link}</a>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
