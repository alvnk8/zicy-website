---
// The live pricing page (/pricing). Every price and count comes from src/data/pricing.ts and the
// pricing/* components; nothing is hard-coded on this page. The sitewide SoftwareApplication offers
// live in src/components/Schema.astro and must stay in sync with the tiers in data/pricing.ts.
import BaseLayout from '../layouts/BaseLayout.astro';
import TierCard from '../components/pricing/TierCard.astro';
import AnnualToggle from '../components/pricing/AnnualToggle.astro';
import AgencyBlock from '../components/pricing/AgencyBlock.astro';
import ContentModule from '../components/pricing/ContentModule.astro';
import MultiMarket from '../components/pricing/MultiMarket.astro';
import ComparisonTable from '../components/pricing/ComparisonTable.astro';
import PricingFAQ from '../components/pricing/PricingFAQ.astro';
import { CORE_TIERS, AGENCY_TIERS, PRICING_FAQS } from '../data/pricing';
import { SITE } from '../data/site';

const title = 'Zicy pricing, all five AI engines on every plan';
const description =
  'All five AI engines, every plan. No per-engine add-ons. Scale from Starter to Enterprise, plus an agency track with pooled prompts. For small and mid-sized businesses, no AEO specialist required.';

// Offer schema: one Product node listing the four core plus two agency tiers as Offers. Tiers with a
// fixed monthly price carry price + priceCurrency; Enterprise and the agency tiers are contact-only
// Offers with a sales URL and no fixed price. isRelatedTo points at the sitewide SoftwareApplication
// (@id from Schema.astro) instead of duplicating it. No aggregateRating, no review.
const pageUrl = `${SITE.url}/pricing`;
const toOffer = (t: (typeof CORE_TIERS)[number]) =>
  t.priceMonthly !== null
    ? { '@type': 'Offer', name: t.name, price: String(t.priceMonthly), priceCurrency: 'USD', url: pageUrl }
    : { '@type': 'Offer', name: t.name, priceCurrency: 'USD', url: t.cta.href, availability: 'https://schema.org/InStock' };
const offerSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Zicy plans',
  description:
    'Zicy pricing plans. All five AI engines on every plan, with no per-engine add-ons.',
  brand: { '@type': 'Organization', name: SITE.name },
  isRelatedTo: { '@id': `${SITE.url}/#app` },
  offers: [...CORE_TIERS, ...AGENCY_TIERS].map(toOffer),
};

// FAQPage from the same array the visible accordion renders, so the text mirrors it verbatim.
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: PRICING_FAQS.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Pricing', item: pageUrl },
  ],
};

// Core ladder grid, rendered here (not via the CoreTiers component) so the SME-first framing
// copy below stays in this file. Tier labels are overridden locally, on top of CORE_TIERS,
// without touching the shared tier data: Starter's own label is untouched.
const coreGridId = 'pv2-core-tiers';
const TIER_LABEL_OVERRIDE: Record<string, string> = {
  growth: 'For a small team or multi-brand business',
  scale: 'For teams tracking many markets',
};
const displayTiers = CORE_TIERS.map((t) =>
  TIER_LABEL_OVERRIDE[t.id] ? { ...t, label: TIER_LABEL_OVERRIDE[t.id] } : t
);
---
<BaseLayout title={title} description={description}>
  <!-- 1. Hero -->
  <section class="hero inner">
    <div class="wrap">
      <span class="eyebrow">Pricing</span>
      <h1>All five AI engines, every plan.<br />No per-engine add-ons.</h1>
      <p class="lead">Be the brand AI gets right, on every engine, without paying extra to see them all.</p>
      <p class="hengines">Every plan tracks ChatGPT, Gemini, Perplexity, Google AI Overviews and Google AI Mode.</p>
      <p class="hmicro mono">
        One tracked prompt is measured across all five engines every day, so 50 prompts is up to
        7,500 AI answers a month.
      </p>
    </div>
  </section>

  <!-- 2. Core ladder + annual toggle -->
  <section class="reveal">
    <div class="wrap">
      <div class="shead" style="max-width:none;text-align:center;margin-bottom:28px">
        <span class="eyebrow" style="justify-content:center"><span class="ix">01</span> Plans</span>
        <h2 style="margin-top:14px">All five engines on every plan.</h2>
      </div>

      <div class="ptoggle-wrap">
        <AnnualToggle target={coreGridId} />
      </div>

      <p class="mono pv2-anchor">
        Starter is $79 a month, less than a single Google Ads click a day in many industries.
        Growth is $199, a fraction of an agency retainer.
      </p>

      <div class="ptiers" id={coreGridId} data-billing="monthly">
        {displayTiers.map((tier) => <TierCard tier={tier} />)}
      </div>

      <p class="pv2-fit"><b>Which plan fits?</b> Owner with one business &rarr; Starter. Small marketing team &rarr;
        <a href="/solutions/smb">Growth</a>. Agency or multi-market &rarr;
        <a href="/solutions/agencies">Scale or Enterprise</a>.
      </p>
    </div>
  </section>

  <!-- 3. Agency track -->
  <AgencyBlock />

  <!-- 4. Anchors for later parts (Part 3 owns FAQ + schema) -->
  <!--SLOT:content-module--><ContentModule />
  <!--SLOT:multi-market--><MultiMarket />
  <!--SLOT:comparison--><ComparisonTable />
  <!--SLOT:faq--><PricingFAQ />
  <!--SLOT:schema-->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(offerSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />
</BaseLayout>

<style>
  .hengines{font-size:15px;color:var(--ink);font-weight:500;margin-top:16px;max-width:60ch;line-height:1.6}
  .hmicro{font-size:13px;color:var(--muted);margin-top:16px;max-width:60ch;line-height:1.7}

  .ptoggle-wrap{margin:0 0 32px}
  .ptiers{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;align-items:stretch}
  @media (max-width:1000px){.ptiers{grid-template-columns:repeat(2,1fr)}}
  @media (max-width:640px){.ptiers{grid-template-columns:1fr}}
  .pv2-anchor{text-align:center;max-width:60ch;margin:-16px auto 32px;font-size:13px;color:var(--muted);letter-spacing:.01em}
  .pv2-fit{text-align:center;max-width:64ch;margin:28px auto 0;font-size:14px;color:var(--ink-2);line-height:1.7}
  .pv2-fit b{color:var(--ink);font-weight:600}
</style>

<!-- Billing swap: global (crosses into TierCard) but namespaced by the grid id so it cannot leak.
     An id selector outranks TierCard's scoped class rules, so no !important is needed. -->
<style is:global>
  #pv2-core-tiers[data-billing="annual"] .amt.is-monthly{display:none}
  #pv2-core-tiers[data-billing="annual"] .amt.is-annual{display:inline}
</style>
