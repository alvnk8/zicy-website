---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Zicy AEO/GEO Consultant — ask anything about AI search visibility';
const description =
  'A free AI consultant for AEO and GEO. Audit a page or ask how to get cited in ChatGPT, Gemini and Perplexity — powered by Growth.pro’s proprietary framework.';

const prompts = [
  { h: 'Can you audit my page?', p: 'Paste a URL and get an on-the-spot read.' },
  { h: 'What is AEO?', p: 'Plain-English answers to the fundamentals.' },
  { h: 'Top 3 AEO strategies', p: 'Tactics to get cited and mentioned.' },
];

const features = [
  'Audit any webpage on the spot',
  'Plain-English answers to AEO/GEO questions',
  'Restart the conversation, share it, or download the transcript',
];
---
<BaseLayout title={title} description={description}>
  <section class="hero inner">
    <div class="wrap">
      <span class="eyebrow">Free tool · AI consultant</span>
      <h1>Your AEO/GEO consultant.</h1>
      <p class="lead">
        Ask Zicy anything about AEO or GEO — Answer and Generative Engine Optimisation. Audit a page,
        or get tactics to be cited in ChatGPT, Gemini, Perplexity and other answer engines.
      </p>
      <!-- §A2: light, attributed Growth.pro mention (the 4th IP surface, flagged for sign-off). -->
      <p class="provenance">Powered by <b>Growth.pro</b>’s proprietary AI visibility framework.</p>
      <div class="cta-row">
        <a class="btn btn-primary btn-lg" href="#consultant">Open the consultant</a>
        <a class="btn btn-ghost btn-lg" href="/platform">See the platform</a>
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="shead"><span class="eyebrow"><span class="ix">01</span> Try a prompt</span><h2>A real answer, before you commit to anything.</h2></div>
      <div class="grid-3">
        {prompts.map((p) => (
          <div class="card"><h3>{p.h}</h3><p>{p.p}</p></div>
        ))}
      </div>

      <!-- Build note: this embeds the existing interactive consultant app. The page
           shell is server-rendered (crawlable); the chat widget hydrates client-side. -->
      <div id="consultant" class="embed-frame" style="margin-top:24px">
        <span>[ EMBED ]<br />Interactive AEO/GEO consultant chat — restart · share · download transcript</span>
      </div>

      <ul class="checklist" style="margin-top:30px">
        {features.map((f) => <li>{f}</li>)}
      </ul>
    </div>
  </section>
</BaseLayout>
