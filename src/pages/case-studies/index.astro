---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { CASES } from '../../data/cases';

const title = 'Zicy case studies, from invisible to AI-cited';
const description =
  'Real AI visibility programmes, measured across major AI platforms. Mention rates, citation rates and share of voice, anonymised pending naming permission.';

// Hero screenshot per tile. The migration left the case-study images in /public (referenced as
// raw <img> in each entry's bodyHtml) and there is no content collection / heroImage field, so we
// resolve the FEATURED shot (each study's first body image, copied into src/assets/case-studies/
// <slug>/) by slug via a glob. astro:assets then emits AVIF/WebP + srcset and sets width/height,
// so there is no layout shift and nothing is served raw from /public. A slug with no asset simply
// renders without an image (graceful — no build failure).
const heroModules = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/case-studies/*/*.{png,jpg,jpeg,webp,avif}',
  { eager: true }
);
const heroBySlug: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(heroModules)) {
  const slug = path.split('/assets/case-studies/')[1]?.split('/')[0];
  if (slug) heroBySlug[slug] = mod.default;
}
---
<BaseLayout title={title} description={description}>
  <section class="hero inner">
    <div class="wrap">
      <span class="eyebrow">Case studies</span>
      <h1>From invisible to AI-cited.</h1>
      <p class="lead">Real programmes, measured across major AI platforms.</p>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="cs-grid">
        {CASES.map((c) => (
          <a class="card cs-card" href={`/case-studies/${c.slug}`}>
            {heroBySlug[c.slug] && (
              <div class="cs-shot">
                <Picture
                  src={heroBySlug[c.slug]}
                  formats={['avif', 'webp']}
                  widths={[300, 420, 560, 760]}
                  sizes="(max-width: 620px) 92vw, (max-width: 980px) 46vw, 360px"
                  alt={`Zicy AI visibility dashboard, ${c.indexTitle}`}
                  loading="lazy"
                />
              </div>
            )}
            <span class="k">{c.indexMeta}</span>
            <h3>{c.indexTitle}</h3>
            <div class="mono" style="font-size:36px;color:var(--violet-700);margin-top:14px;font-variant-numeric:tabular-nums slashed-zero;font-weight:500;letter-spacing:-.02em">{c.big}</div>
            <p style="font-size:13px;color:var(--muted);margin-top:4px">{c.indexSub}</p>
            <span class="arrow">Read the case study →</span>
          </a>
        ))}
      </div>
      <p class="disclosure">
        Measurement: AI brand mention and citation rates across tracked category queries on ChatGPT, Gemini, and Perplexity, via Zicy&rsquo;s measurement infrastructure. Clients anonymised pending naming permission.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* Case-study grid — exactly three tiles per row on desktop, stepping to two then one.
     Brand 8pt spacing (24px desktop/tablet, 20px mobile); wider columns than the old auto-fit
     grid give each card a roomier hero image. */
  .cs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  @media (max-width: 980px) {
    .cs-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 620px) {
    .cs-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }

  /* Hero screenshot, flush to the card's top edges with the card radius. Negative margins cancel
     the card padding (26px 24px); top corners nest just inside the 1px card border. Fixed 16/10
     box + object-fit:cover anchored top so mixed-orientation screenshots crop uniformly. The
     card's existing border + hover shadow are untouched. */
  .cs-shot {
    margin: -26px -24px 18px;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: calc(var(--r-lg) - 1px) calc(var(--r-lg) - 1px) 0 0;
    border-bottom: 1px solid var(--line);
    background: var(--mist);
  }
  .cs-shot :global(picture) {
    display: block;
    width: 100%;
    height: 100%;
  }
  .cs-shot :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }
</style>
