---
import BaseLayout from '../layouts/BaseLayout.astro';
import Screenshot from '../components/Screenshot.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import aiVisibility from '../assets/screenshots/home-ai-visibility.png';
// Proof-layer screenshot — Site Traffic, Search Console view. Demo brand
// "Acme Pickleball Fashion" (illustrative, not a real client). Chosen over the GA4
// "AEO overview" variant because it shows answer-intent queries + branded-search
// behaviour (exactly the proof-layer copy) and displays no uplift %/correlation figure.
import siteTraffic from '../assets/screenshots/home-site-traffic.png';
// Hero screenshot — Brand Intelligence for the demo brand "Vela" (illustrative, fictional).
import heroShot from '../assets/screenshots/home-hero-brand-intelligence.png';
const title = 'Zicy, be the brand AI gets right';
const description =
  "Zicy is the AI visibility platform that shows you what AI says about your brand, whether it's true, and how to fix what's wrong, then proves the fix moved demand. Across ChatGPT, Gemini, Perplexity, Google AI Overviews and Google AI Mode, in every language. Built by Growth.pro.";

// Page-level structured data. The Zicy Organization, WebSite and SoftwareApplication entities
// are sitewide (src/components/Schema.astro); only the homepage FAQPage is page-level here.

// FAQ — verbatim copy. The same array renders the accordion AND the FAQPage schema, so the
// structured-data answers always match the visible (server-rendered) answers.
const faqs = [
  {
    q: 'What is AI visibility?',
    a: 'AI visibility is how often, how accurately and how prominently your brand appears when people ask AI assistants about your category. It is the AI-era equivalent of search ranking, measured inside the answer the engine builds rather than in a list of links. Zicy measures it across ChatGPT, Gemini, Perplexity, Google AI Overviews and Google AI Mode.',
  },
  {
    q: 'Which engines does Zicy track?',
    a: 'Zicy tracks the five engines that decide most answers: ChatGPT, Gemini, Perplexity, Google AI Overviews and Google AI Mode. Enterprise plans can add others, such as Grok and DeepSeek. Every tracked prompt runs across each engine, so one prompt returns a reading from all five.',
  },
  {
    q: 'How is Zicy different from a rank tracker or a mention monitor?',
    a: 'Most tools tell you whether your brand was named. Zicy also tells you whether what AI said was true, why it said it, and how to fix it, then connects the fix to demand. That is the full loop (measure, diagnose, act, prove) in one place, rather than a dashboard that stops at the scoreboard.',
  },
  {
    q: 'Does Zicy place media or write content for me?',
    a: 'Zicy measures, diagnoses and gives you the tools to fix what is in your control: schema, llms.txt and content. It does not place earned media; your team earns that on its merits, and Zicy shows whether it moved the answer. For a fully managed programme, Growth.pro, the consultancy that built Zicy, runs done-for-you engagements.',
  },
  {
    q: "Is improving AI visibility safe under Google's spam policies?",
    a: "Yes. Zicy's content tooling is built to current AEO/GEO best practice and aligned with Google's latest spam policies, updated in May 2026 to cover AI Overviews and AI Mode. The approach is to make genuine expertise easier for AI to find, verify and trust, not to game the system.",
  },
  {
    q: 'How much does Zicy cost?',
    a: 'Zicy starts at $79 per month on Starter, with Growth at $199, Scale at $449, and custom Enterprise plans. Starter and Growth include a 7-day free trial, and the annual plan gives you 13 months for the price of 12.',
  },
  {
    q: 'Who is Zicy for?',
    a: 'Zicy is built for five groups who own the answer: brands, small businesses, PR and communications teams, marketing and creative agencies, and publishers. Each gets a tailored view of the same underlying platform. See the solutions section above, or <a href="/solutions/smb">Zicy for small businesses</a> if you run the business yourself.',
  },
];

const faqPage = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

// Three sourced stats — every figure carries publisher + sample + year inline. Do not alter.
const shiftStats = [
  {
    n: '73%',
    label: 'of brands ranking on Google page one have zero mentions in AI answers.',
    source: 'Wellows GEO Visibility Research, 2025',
  },
  {
    n: '62%',
    label: 'of consumers trust AI tools to guide their brand decisions.',
    source: 'Yext / Researchscape, n=2,237, 2025',
  },
  {
    n: '38%',
    label: 'drop in outbound clicks when AI Overviews appear.',
    source: 'Agarwal & Sen, Carnegie Mellon, randomised field experiment, 2026',
  },
];

const loopCards = [
  {
    k: '01 · Measure',
    h: 'Measure',
    p: 'Mention coverage, citation rate, share of voice and ranking across the five engines, weekly.',
  },
  {
    k: '02 · Diagnose',
    h: 'Diagnose',
    p: 'The AI Reality Score flags hallucinations, outdated claims and entity gaps before a buyer sees them.',
  },
  {
    k: '03 · Act',
    h: 'Act',
    p: 'Schema, llms.txt and content tooling, built to current best practice.',
  },
  {
    k: '04 · Prove',
    h: 'Prove',
    p: 'AI-referred traffic, downstream engagement, and the link back to demand.',
  },
];

const truthCards = [
  {
    h: 'Truth, not just mentions.',
    p: 'A hallucination or an outdated claim, caught and surfaced before it reaches a buyer mid-decision.',
  },
  {
    h: 'Every engine, every language.',
    p: 'APAC-native coverage across the five engines and the languages your buyers actually use, not English-first, with everything else an afterthought.',
  },
  {
    h: 'The whole loop.',
    p: 'Measure, diagnose, act, and prove, all in one place.',
  },
];

// Proof-layer capability bullets only — no fabricated correlation result, uplift or ROI number.
const proofBullets = [
  'AI-referred sessions, tied back to the visibility work.',
  'Answer-intent queries and branded-search behaviour, from GA4 and Search Console.',
  'The link between winning the answer and movement in demand, defensible in a budget review.',
];

const solutionCards = [
  {
    eyebrow: 'For brands',
    p: 'Know whether AI got you right, not just whether it named you.',
    href: '/solutions/brands',
    link: 'For brands →',
  },
  {
    eyebrow: 'For small businesses',
    p: 'Know what AI tells your customers, and fix it, without a specialist.',
    href: '/solutions/smb',
    link: 'For small businesses →',
  },
  {
    eyebrow: 'For PR & communications',
    p: 'Clippings count coverage. Zicy proves it moved the answer.',
    href: '/solutions/pr',
    link: 'For PR →',
  },
  {
    eyebrow: 'For marketing & creative agencies',
    p: 'Sell your client the fix, not just the diagnosis.',
    href: '/solutions/agencies',
    link: 'For agencies →',
  },
  {
    eyebrow: 'For publishers',
    p: "Traffic told you who read you. Zicy tells you who's using you without saying so.",
    href: '/solutions/publishers',
    link: 'For publishers →',
  },
];
---
<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqPage)} />
  </Fragment>

  <!-- 1. Hero — asymmetric grid, measurement-grid atmosphere, staggered load,
       live "what AI says about you" card with truth-signal pills + Reality Score ring. -->
  <section class="hero">
    <div class="grid-field" aria-hidden="true"></div>
    <div class="wrap hero-grid">
      <div class="hcol">
        <span class="eyebrow rise d1">AI visibility</span>
        <h1 class="rise d2">Be the brand AI gets right.</h1>
        <p class="sub rise d3">
          Buyers ask AI about your category every day. Zicy shows you what it says, whether
          it&rsquo;s true, how to fix what&rsquo;s wrong, and proves the fix moved demand.
          Across every engine, every language.
        </p>
        <div class="hcta rise d4">
          <a class="btn btn-p" href="https://app.zicy.com/register">Try for free</a>
          <a class="btn btn-o" href="/platform">See the platform</a>
        </div>
        <p class="hero-price rise d4">From <span class="mono">$79/mo</span> &middot; 7-day free trial &middot; no card required</p>
        <div class="engines rise d5">
          <b>ChatGPT</b> &middot; <b>Gemini</b> &middot; <b>Perplexity</b> &middot;
          <b>Google AI Overviews</b> &middot; <b>Google AI Mode</b>
          <span class="cap">Coverage across the five engines that decide the answer.</span>
        </div>
      </div>

      <div class="hvis rise d5">
        <Screenshot
          src={heroShot}
          alt="Zicy Brand Intelligence report showing AI perception, coverage and alignment scores and a plain-English perception summary for a demo brand."
          caption="Illustrative product view with sample data."
          priority="eager"
        />
      </div>
    </div>
  </section>

  <!-- 2. 01 · The shift — three sourced stats + divergence line -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">01</span> The shift</span>
        <h2>Ranking on Google no longer means being seen.</h2>
        <p>
          Search has changed. When someone asks AI about your category, the engine builds one
          answer before the buyer ever clicks. If your brand isn&rsquo;t in that answer, or
          isn&rsquo;t in it accurately, the decision gets made without you.
        </p>
      </div>
      <div class="grid-3">
        {shiftStats.map((s) => (
          <div class="stat">
            <div class="n">{s.n}</div>
            <div class="t">{s.label}</div>
            <div class="s">Source: {s.source}</div>
          </div>
        ))}
      </div>
      <p class="mono" style="margin-top:24px;font-size:13px;color:var(--muted);letter-spacing:.01em">
        And SEO is not AI visibility: just 12% of AI citations overlap with a brand&rsquo;s Google
        top-10 results. (Ahrefs, 15,000 prompts, 2025)
      </p>
      <p class="pullquote">The answer&rsquo;s already written. Make sure you&rsquo;re in it.</p>
    </div>
  </section>

  <!-- 3. 02 · The platform — the closed loop, four cards (#loop anchor) -->
  <section id="loop">
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">02</span> The platform</span>
        <h2>One loop: measure, diagnose, act, prove.</h2>
        <p>
          Most tools stop at the dashboard. Zicy closes the loop: see what AI says, fix what&rsquo;s
          broken, prove the work moved demand.
        </p>
      </div>
      <div class="grid4">
        {loopCards.map((s) => (
          <div class="card">
            <span class="k">{s.k}</span>
            <h3>{s.h}</h3>
            <p>{s.p}</p>
          </div>
        ))}
      </div>
      <div style="text-align:center;margin-top:34px">
        <a class="btn btn-t" href="/platform">See the full platform →</a>
      </div>
    </div>
  </section>

  <!-- 4. 03 · The truth layer — three differentiators with grad bars -->
  <section class="truth">
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">03</span> The truth layer</span>
        <h2>First, AI has to get you right.</h2>
        <p>
          Being mentioned isn&rsquo;t the same as being described accurately. Zicy reads what AI
          actually says about your brand and flags hallucinations and outdated claims before a
          buyer acts on them.
        </p>
      </div>
      <div class="three">
        {truthCards.map((c) => (
          <div>
            <div class="bar" aria-hidden="true"></div>
            <h3>{c.h}</h3>
            <p>{c.p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. 04 · The proof layer (NEW) — capability copy + bullets + Site Traffic placeholder -->
  <section>
    <div class="wrap">
      <!-- Two-column split: header + intro + bullets in the left column, screenshot in the
           right, both top-aligned (.feature-split is align-items:start) so the image rises to
           the top of the section header rather than sitting below a full-width header. -->
      <div class="feature-split">
        <div>
          <div class="shead" style="margin-bottom:28px">
            <span class="eyebrow"><span class="ix">04</span> The proof layer</span>
            <h2>Zicy answers the question your CFO actually asks: did it move demand?</h2>
            <p>
              Does winning the AI answer move demand? Zicy connects AI-referred sessions,
              answer-intent queries and branded-search behaviour from GA4 and Search Console to the
              visibility work, so AI visibility stops being a vanity metric and becomes a
              line you can defend in a budget review.
            </p>
          </div>
          <ul class="checklist">
            {proofBullets.map((b) => <li>{b}</li>)}
          </ul>
        </div>
        <Screenshot
          src={siteTraffic}
          alt="Zicy Site Traffic, Search Console view, answer-intent queries, question impressions and clicks, and branded-search performance (impressions, clicks, average CTR and average position) connected to the AI visibility work."
          caption="Site Traffic: answer-intent queries and branded-search behaviour, connected to the visibility work."
        />
      </div>
    </div>
  </section>

  <!-- 6. 05 · Solutions — five linked ICP cards -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">05</span> Solutions</span>
        <h2>Built for the people who own the answer.</h2>
      </div>
      <div class="grid4 grid-sol">
        {solutionCards.map((c) => (
          <a class="card" href={c.href}>
            <span class="k">{c.eyebrow}</span>
            <p>{c.p}</p>
            <span class="arrow">{c.link}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 7. 06 · Inside the platform — real dashboard screenshot + three module cards -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">06</span> Inside the platform</span>
        <h2>The dashboard you&rsquo;ll actually use.</h2>
        <p>A working view of how AI describes your brand, across every engine, every week.</p>
      </div>

      <!-- Real product screenshot. Brand shown ("Acme Pickleball Fashion") is a demo brand,
           not a real client. Below the fold, so it lazy-loads. -->
      <Screenshot
        src={aiVisibility}
        alt="Zicy AI Visibility dashboard showing brand mention coverage, share of voice, average AI ranking, and a per-platform radar across ChatGPT, Gemini, Perplexity and Google AI."
        caption="The AI Visibility dashboard: your four primary KPIs across every engine."
      />

      <div class="bento" style="margin-top:36px">
        <div class="card">
          <span class="k">Brand Intelligence</span>
          <h3>The truth layer.</h3>
          <p>The <a href="/platform/ai-reality-score">AI Reality Score</a> flags hallucinations, outdated claims and entity gaps before a buyer sees them.</p>
          <div class="signals">
            <div class="row"><span class="dot ok" aria-hidden="true"></span><span class="lab">Accurate</span><span class="hc-tag ok" style="margin-left:auto">99%</span></div>
            <div class="row"><span class="dot warn" aria-hidden="true"></span><span class="lab">Outdated</span><span class="hc-tag warn" style="margin-left:auto">3</span></div>
            <div class="row"><span class="dot flag" aria-hidden="true"></span><span class="lab">Hallucination</span><span class="hc-tag flag" style="margin-left:auto">1</span></div>
          </div>
        </div>
        <div class="card">
          <span class="k">Citation Analysis</span>
          <h3>Who AI cites about you.</h3>
          <p>Narrative control and competitor share, owned, earned, competitor and uncited sources, by topic.</p>
          <div class="bars" style="margin-top:18px">
            <div class="br-r"><span class="nm">Owned</span><span class="tk"><i style="width:24%"></i></span><span class="pc">24%</span></div>
            <div class="br-r"><span class="nm">Earned</span><span class="tk"><i style="width:33%;background:var(--sky-700)"></i></span><span class="pc">33%</span></div>
            <div class="br-r"><span class="nm">Competitor</span><span class="tk"><i style="width:40%;background:var(--magenta)"></i></span><span class="pc">40%</span></div>
            <div class="br-r"><span class="nm">Uncited</span><span class="tk"><i style="width:3%;background:var(--muted)"></i></span><span class="pc">3%</span></div>
          </div>
        </div>
        <div class="card">
          <span class="k">Action Center</span>
          <h3>Fix what&rsquo;s broken.</h3>
          <p>Schema, llms.txt and content tooling, built to current AEO/GEO best practice.</p>
          <ul class="checklist" style="margin-top:14px;max-width:none">
            <li>Schema generator</li>
            <li>llms.txt builder</li>
            <li>Content optimiser</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. 07 · Proof band — anonymised case, locked disclosure footer -->
  <section class="proof">
    <div class="wrap">
      <span class="eyebrow" style="color:#9C92C4;margin-bottom:10px"><span class="ix" style="color:#BEB9DA">07</span> Proof</span>
      <div class="n">90.61%</div>
      <div class="gbar" aria-hidden="true"></div>
      <div class="lab">AI mention rate &middot; professional services &middot; from a near-zero baseline</div>
      <p class="pnote">
        Measurement: AI brand mention and citation rates across tracked category queries on
        ChatGPT, Gemini and Perplexity, via Zicy&rsquo;s measurement infrastructure. Client
        anonymised pending naming permission.
      </p>
      <div style="margin-top:30px">
        <a class="btn" style="border:1px solid rgba(255,255,255,.3);color:#fff;background:transparent" href="/case-studies">See more case studies →</a>
      </div>
    </div>
  </section>

  <!-- 9. Built by Growth.pro — no index per brief -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow">Built by Growth.pro</span>
        <h2>An AI visibility consultancy, turned into a platform.</h2>
      </div>
      <div style="max-width:760px">
        <p class="sub" style="font-size:18px">
          Zicy was built by Growth.pro, the AI visibility consultancy that runs done-for-you
          programmes for enterprise brands. The platform is open to everyone; the managed service
          is selective. The frameworks behind that service, the
          AI Visibility Operating System, the PAVA Framework and
          AI Citation Enablement, are Growth.pro&rsquo;s. Built in Penang, under
          Malaysia Digital (MD) status, covering every engine and every language.
        </p>
        <div class="hcta" style="margin-top:24px">
          <a class="btn btn-t" href="/about">Read the story →</a>
          <a class="btn btn-t" href="https://www.growth.pro/" target="_blank" rel="noopener noreferrer">Explore done-for-you →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 10. FAQ — native <details> accordion; answers are in static HTML + FAQPage schema -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow">FAQ</span>
        <h2>Questions buyers ask, and AI asks too.</h2>
      </div>
      <FaqAccordion items={faqs} defaultOpen={0} />
    </div>
  </section>

  <!-- 11. Final CTA -->
  <section class="final">
    <div class="wrap">
      <h2>See your brand the way AI describes it.</h2>
      <p>All five engines. Starter from $79/mo. 7-day free trial. No commitment.</p>
      <div class="hcta">
        <a class="btn btn-p" href="https://app.zicy.com/register">Try for free</a>
        <a class="btn btn-o" href="/pricing">See pricing</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* FIX 1 — hero price/trial micro-line. ~12px below the CTAs; "$79/mo" renders in JetBrains
     Mono via the global .mono class. Colour is --ink-2 (secondary text): measured >=6:1 on the
     hero gradient (#F7F8FB -> #EAEEF8); --muted would fall to ~4.3:1 on the darker stop and fail
     WCAG AA, so it is not used here. Scoped to .hcol so only the hero CTA row is affected. */
  .hcol .hcta { margin-bottom: 12px; }
  .hero-price { margin: 0 0 24px; font-family: var(--fs); font-size: 13px; line-height: 1.5; color: var(--ink-2); }
  .hero-price .mono { font-size: 13px; }

  /* FIX 2 — AI Reality Score legend inside the (white) hero demo card. --ink-2 ~6.8:1 on white. */
  .hc-legend { margin-top: 10px; font-size: 12px; line-height: 1.45; color: var(--ink-2); }

  /* 05 Solutions — five audience cards. Drop the auto-fit min to 200px so all five fit one row at
     the 1200px .wrap on desktop, wrapping cleanly to fewer per row below. Scoped to this page, so
     the shared .grid4 (also used on /platform) is unchanged. */
  .grid-sol { grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); }
</style>
