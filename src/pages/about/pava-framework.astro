---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import { SITE } from '../../data/site';

const title = "The PAVA Framework, Growth.pro's model for AI visibility";
const description =
  "The PAVA Framework is Growth.pro's four-pillar model for diagnosing and improving a brand's AI visibility, covering Presence, Authority, Visibility, and Amplification in sequence.";

const url = `${SITE.url}/about/pava-framework`;
const name = 'The PAVA Framework';
const datePublished = '2026-06-19';
const definition =
  "The PAVA Framework is Growth.pro's four-pillar model for diagnosing and improving a brand's AI visibility, covering Presence, Authority, Visibility, and Amplification in sequence.";

// How it works: the four pillars, in sequence, each with the work that closes the gap.
const pillars = [
  {
    k: 'P',
    h: 'Presence',
    p: 'Is the brand entity clearly, consistently, and completely defined across every surface AI systems ingest? Gaps here mean AI cannot resolve the brand as a single coherent entity.',
    fixes: 'Entity schema, llms.txt, NAP consistency, social handle standardisation.',
  },
  {
    k: 'A',
    h: 'Authority',
    p: 'Is the brand trusted and corroborated by independent third-party sources? AI systems weight entities that appear across multiple credible, non-self-referential sources.',
    fixes: 'Earned media, partner mentions, citations, third-party directory listings, founder profiles.',
  },
  {
    k: 'V',
    h: 'Visibility',
    p: 'Does the brand appear in AI answers for the category queries its buyers actually ask? This is the measurement pillar: tracked prompts, mention coverage, share of voice, average AI ranking.',
    fixes: 'Content aligned to answer-intent queries, topical authority, citation-worthy source trails.',
  },
  {
    k: 'A',
    h: 'Amplification',
    p: 'Does AI visibility translate to real demand? The proof pillar: AI-referred sessions, branded-search lift, answer-intent queries, and the correlation between winning AI answers and downstream commercial outcomes.',
    fixes: '',
  },
];

// How Zicy operationalises PAVA: each pillar maps to specific platform modules.
const modules = [
  {
    stage: 'Presence',
    name: 'Action Center',
    desc: 'The schema generator and llms.txt builder, so the brand entity is machine-readable and consistent across the surfaces AI reads.',
  },
  {
    stage: 'Authority',
    name: 'Citation Analysis + Content Generator',
    desc: 'See which independent sources AI cites in the category, then produce citation-worthy content to earn more of them.',
  },
  {
    stage: 'Visibility',
    name: 'AI Visibility, Brand Intelligence + Competitive AI Performance',
    desc: 'Mention coverage, citation rate, share of voice and average ranking across the five engines, with the AI Reality Score and your standing against named rivals.',
  },
  {
    stage: 'Amplification',
    name: 'Site Traffic',
    desc: 'AI-referred sessions from GA4 and Search Console, tying winning the answer back to demand.',
  },
];

const faqs = [
  {
    q: 'What does PAVA stand for?',
    a: "PAVA stands for Presence, Authority, Visibility, and Amplification, the four sequential pillars of the framework Growth.pro uses to diagnose and improve a brand's AI visibility.",
  },
  {
    q: 'Who created the PAVA Framework?',
    a: "Growth.pro created the PAVA Framework. It is the strategic and diagnostic model behind Growth.pro's AI visibility consultancy and managed-service programmes. Zicy, the platform built by Growth.pro, operationalises PAVA in software.",
  },
  {
    q: 'How is PAVA different from a standard SEO audit?',
    a: 'A standard SEO audit measures search-engine signals such as backlinks, page speed, and keyword rankings. PAVA measures the four signals that determine AI answer-engine visibility: whether the entity is clearly defined, whether it is independently corroborated, whether it appears in AI answers for buyer queries, and whether that visibility moves demand.',
  },
  {
    q: 'Can I use the PAVA Framework without Growth.pro?',
    a: "Zicy's platform operationalises the measurement and action layers of PAVA as a self-serve tool. For a fully managed PAVA programme across all four pillars, Growth.pro runs done-for-you engagements for enterprise brands.",
  },
  {
    q: 'Where does the AI Reality Score fit in the PAVA Framework?',
    a: 'The AI Reality Score sits inside the Visibility pillar, it measures not just whether a brand appears in AI answers, but whether those answers describe the brand accurately. A high mention rate with a low AI Reality Score signals a Visibility problem of a specific kind: presence without accuracy.',
  },
];

const faqMain = faqs.map((f) => ({
  '@type': 'Question',
  name: f.q,
  acceptedAnswer: { '@type': 'Answer', text: f.a },
}));

// BreadcrumbList: separate block.
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: 'About', item: `${SITE.url}/about` },
    { '@type': 'ListItem', position: 3, name, item: url },
  ],
};

// Article + DefinedTerm.
const articleGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'TechArticle',
      '@id': `${url}#article`,
      name,
      headline: name,
      description: definition,
      url,
      inLanguage: 'en',
      datePublished,
      author: { '@type': 'Organization', name: 'Growth.pro', url: 'https://www.growth.pro/' },
      publisher: { '@id': `${SITE.url}/#org` },
      mainEntityOfPage: url,
      about: { '@id': `${url}#term` },
    },
    {
      '@type': 'DefinedTerm',
      '@id': `${url}#term`,
      name: 'PAVA Framework',
      description: definition,
      inDefinedTermSet: {
        '@type': 'DefinedTermSet',
        name: 'Growth.pro AI Visibility Frameworks',
        url: `${SITE.url}/about`,
      },
    },
  ],
};

// FAQPage: separate block.
const faqPage = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqMain,
};
---
<BaseLayout title={title} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleGraph)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqPage)} />

  <!-- 1. Hero: breadcrumb + pill label + H1 + one-sentence definition -->
  <section class="hero inner">
    <div class="wrap">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="sep" aria-hidden="true">&rsaquo;</span>
        <a href="/about">About</a>
        <span class="sep" aria-hidden="true">&rsaquo;</span>
        <span class="here" aria-current="page">{name}</span>
      </nav>
      <span class="pill">Growth.pro framework &middot; operationalised by Zicy</span>
      <h1>{name}</h1>
      <p class="def">{definition}</p>
    </div>
  </section>

  <!-- 2. Why it matters -->
  <section style="background:var(--lavender)">
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">01</span> Why it matters</span>
        <h2>A score tells you where you stand. PAVA tells you why.</h2>
      </div>
      <div style="max-width:760px">
        <p class="lead" style="font-size:18px">
          When someone asks AI about your category, the engine builds one answer before the buyer
          reaches your site. If you are absent or described inaccurately, you need to know the cause,
          not just a number that moved.
        </p>
        <p style="margin-top:16px">
          PAVA is a sequence, not a checklist. Each pillar depends on the one before it: if AI cannot
          resolve who you are (Presence), no amount of content will earn you authority or visibility,
          and visibility that never reaches demand is hard to defend in a budget review. PAVA orders
          the work so you fix the real constraint first.
        </p>
        <p style="margin-top:16px">
          It is one of <a href="/about">Growth.pro&rsquo;s frameworks</a>, operationalised by Zicy,
          and it is built around measured outcomes rather than activity. See documented results on
          <a href="/case-studies">our case studies</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- 3. How it works -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">02</span> How it works</span>
        <h2>Four pillars, in sequence.</h2>
      </div>
      <div class="grid-2">
        {pillars.map((s) => (
          <div class="card">
            <span class="stage-mark" aria-hidden="true">{s.k}</span>
            <h3>{s.h}</h3>
            <p>{s.p}</p>
            {s.fixes && <p class="fixes"><b>Fixes:</b> {s.fixes}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. How Zicy operationalises it -->
  <section style="background:var(--lavender)">
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">03</span> How Zicy operationalises it</span>
        <h2>Each pillar maps to the platform.</h2>
      </div>
      <div class="grid-2">
        {modules.map((m) => (
          <div class="card">
            <span class="eyebrow">{m.stage}</span>
            <h3>{m.name}</h3>
            <p>{m.desc}</p>
          </div>
        ))}
      </div>
      <p style="margin-top:24px">
        <a class="btn btn-t" href="/platform">See the full platform &rarr;</a>
        <a class="btn btn-t" href="/solutions/brands">PAVA for brands &rarr;</a>
      </p>
    </div>
  </section>

  <!-- 5. How Growth.pro applies it -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">04</span> How Growth.pro applies it</span>
        <h2>The framework, run for you.</h2>
      </div>
      <div style="max-width:760px">
        <p class="lead" style="font-size:18px">
          Growth.pro applies PAVA through done-for-you programmes: full diagnostic, strategy,
          execution and governance across all four pillars. The Zicy platform puts the measurement
          and action layers in your hands; the managed service runs the whole sequence for teams that
          want the work done for them.
        </p>
        <div class="cta-row" style="margin-top:24px">
          <a class="btn btn-o" href="/done-for-you">Explore done-for-you</a>
          <a class="btn btn-t" href="https://www.growth.pro/" target="_blank" rel="noopener noreferrer">Growth.pro &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. FAQ -->
  <section style="background:var(--lavender)">
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow">FAQ</span>
        <h2>Questions about PAVA.</h2>
      </div>
      <FaqAccordion items={faqs} defaultOpen={0} />
    </div>
  </section>

  <!-- 7. CTAs -->
  <section class="final">
    <div class="wrap">
      <h2>Put PAVA to work on your brand.</h2>
      <p>Diagnose Presence, Authority, Visibility and Amplification across all five engines.</p>
      <div class="hcta">
        <a class="btn btn-p" href="https://app.zicy.com/register">Try Zicy free</a>
        <a class="btn btn-o" href="/done-for-you">Explore done-for-you</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Breadcrumb: tokens only, no hardcoded hex. */
  .crumbs{display:flex;flex-wrap:wrap;align-items:center;gap:8px;font-size:13px;color:var(--muted);margin-bottom:18px}
  .crumbs a{color:var(--muted)}
  .crumbs a:hover{color:var(--indigo)}
  .crumbs .sep{color:var(--line-2)}
  .crumbs .here{color:var(--ink)}

  /* Pill label. */
  .pill{
    display:inline-block;margin-bottom:16px;padding:6px 14px;border-radius:999px;
    background:var(--lavender);border:0.5px solid var(--line);
    font-family:var(--mono);font-size:11.5px;letter-spacing:.06em;text-transform:uppercase;
    color:var(--indigo);font-weight:500;
  }

  /* One-sentence definition, weighted as the extractable answer. */
  .def{font-family:var(--display);font-size:clamp(20px,2.4vw,26px);line-height:1.45;color:var(--ink);max-width:820px;letter-spacing:-0.01em}

  /* Stage letter mark on the "how it works" cards. */
  .stage-mark{
    display:inline-flex;align-items:center;justify-content:center;
    width:34px;height:34px;border-radius:9px;margin-bottom:12px;
    font-family:var(--display);font-weight:700;font-size:17px;
    color:#fff;background:var(--violet);
  }
  .fixes{margin-top:10px;font-size:13.5px;color:var(--muted);line-height:1.55}
  .fixes b{color:var(--ink)}
</style>
