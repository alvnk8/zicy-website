---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import { SITE } from '../../data/site';

const title = "AI Citation Enablement (AICE), Growth.pro's citation practice";
const description =
  "AI Citation Enablement (AICE) is Growth.pro's practice of making a brand's content and entity data easy for AI engines to find, trust, and cite as a source in their answers.";

const url = `${SITE.url}/about/ai-citation-enablement`;
const name = 'AI Citation Enablement';
const datePublished = '2026-06-19';
const definition =
  "AI Citation Enablement (AICE) is Growth.pro's practice of making a brand's content and entity data easy for AI engines to find, trust, and cite as a source in their answers.";

// How it works: the four functions.
const functions = [
  {
    n: '01',
    h: 'Make entities citable',
    p: "The brand's core facts, what it does, who it serves, what makes it different, must be machine-readable, consistent, and structured in formats AI systems ingest. Schema markup, llms.txt, and entity-level consistency are the starting point.",
  },
  {
    n: '02',
    h: 'Engineer source trails',
    p: 'AI engines cite sources they have ingested and trust. AICE identifies the gap between what the brand publishes and what AI actually retrieves, then closes it, through content that matches answer-intent queries and through structured citations that give AI a clear trail back to the brand.',
  },
  {
    n: '03',
    h: 'Improve retrievability',
    p: 'Content must be formatted, structured, and hosted in ways that make it easy for AI crawlers to retrieve, parse, and index. This overlaps with technical AEO: page speed, crawlability, clean HTML, structured data.',
  },
  {
    n: '04',
    h: 'Strengthen citation-worthiness',
    p: 'AI engines weight content from sources they perceive as authoritative and corroborated. AICE builds the external signal set, third-party mentions, earned media, directory presence, partner citations, that makes a brand a safer source for an AI to cite.',
  },
];

// How Zicy operationalises AICE.
const modules = [
  {
    fn: 'See it',
    name: 'Citation Analysis',
    desc: 'Shows the owned, earned, competitor and uncited breakdown, and identifies which sources AI currently cites instead of the brand.',
  },
  {
    fn: 'Make it citable',
    name: 'Action Center',
    desc: 'The schema generator and llms.txt builder, so the brand entity is machine-readable and retrievable.',
  },
  {
    fn: 'Earn citations',
    name: 'Content Generator',
    desc: 'Creates citation-worthy, answer-intent content grounded in genuine expertise.',
  },
  {
    fn: 'Upgrade what exists',
    name: 'Content Optimizer',
    desc: 'Upgrades existing content to current AEO and GEO best practice.',
  },
];

const faqs = [
  {
    q: 'What is AI Citation Enablement?',
    a: "AI Citation Enablement (AICE) is Growth.pro's practice of making a brand's content and entity data structured, credible, and retrievable enough that AI engines cite the brand as a source in their answers, not just mention it, but actively credit it.",
  },
  {
    q: 'What is the difference between being mentioned and being cited in AI?',
    a: 'A mention means the AI named your brand in its answer. A citation means the AI linked to your website or credited your content as a source. AICE targets citations specifically because cited brands carry more authority in AI answers and receive more referral traffic from AI platforms.',
  },
  {
    q: 'Who created AI Citation Enablement?',
    a: "AI Citation Enablement is a Growth.pro practice. Zicy operationalises its core technical and content components in the platform's Citation Analysis, Action Center, and content tooling modules.",
  },
  {
    q: 'How does AI Citation Enablement relate to traditional link building?',
    a: 'Traditional link building targets search-engine crawlers and PageRank. AI Citation Enablement targets the sources, formats, and authority signals that AI engines use when deciding which brands and URLs to cite in generated answers. The mechanisms overlap in some areas (third-party credibility matters in both), but the optimisation targets are different.',
  },
  {
    q: 'Can I do AI Citation Enablement with Zicy alone?',
    a: "Zicy's platform handles the technical layer: schema, llms.txt, citation analysis, and content optimisation. The earned-citation and source-trail engineering that AICE requires at scale, placing the brand in the right external sources, is the work Growth.pro's done-for-you programmes are built to execute.",
  },
];

const faqMain = faqs.map((f) => ({
  '@type': 'Question',
  name: f.q,
  acceptedAnswer: { '@type': 'Answer', text: f.a },
}));

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: 'About', item: `${SITE.url}/about` },
    { '@type': 'ListItem', position: 3, name, item: url },
  ],
};

const articleGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'TechArticle',
      '@id': `${url}#article`,
      name,
      headline: name,
      description: definition,
      url,
      inLanguage: 'en',
      datePublished,
      author: { '@type': 'Organization', name: 'Growth.pro', url: 'https://www.growth.pro/' },
      publisher: { '@id': `${SITE.url}/#org` },
      mainEntityOfPage: url,
      about: { '@id': `${url}#term` },
    },
    {
      '@type': 'DefinedTerm',
      '@id': `${url}#term`,
      name: 'AI Citation Enablement',
      description: definition,
      inDefinedTermSet: {
        '@type': 'DefinedTermSet',
        name: 'Growth.pro AI Visibility Frameworks',
        url: `${SITE.url}/about`,
      },
    },
  ],
};

const faqPage = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqMain,
};
---
<BaseLayout title={title} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleGraph)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqPage)} />

  <!-- 1. Hero -->
  <section class="hero inner">
    <div class="wrap">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="sep" aria-hidden="true">&rsaquo;</span>
        <a href="/about">About</a>
        <span class="sep" aria-hidden="true">&rsaquo;</span>
        <span class="here" aria-current="page">{name}</span>
      </nav>
      <span class="pill">Growth.pro framework &middot; operationalised by Zicy</span>
      <h1>{name}</h1>
      <p class="def">{definition}</p>
    </div>
  </section>

  <!-- 2. Why it matters -->
  <section style="background:var(--lavender)">
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">01</span> Why it matters</span>
        <h2>Being mentioned is not being cited.</h2>
      </div>
      <div style="max-width:760px">
        <p class="lead" style="font-size:18px">
          A citation attributes and links a brand as a source. It is the durable unit of AI
          visibility, the part that still carries value as referral clicks fall, and it is what a
          brand can defend and license later.
        </p>
        <p style="margin-top:16px">
          Most brands are technically hard to cite regardless of how good their content is: a weak
          entity definition, no llms.txt, content AI cannot retrieve, or no external corroboration. AI
          Citation Enablement is the practice that closes that gap, across find, trust and cite.
        </p>
        <p style="margin-top:16px">
          It is one of <a href="/about">Growth.pro&rsquo;s frameworks</a>, operationalised by Zicy.
          See documented outcomes on <a href="/case-studies">our case studies</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- 3. How it works -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">02</span> How it works</span>
        <h2>Four functions, one outcome: easy to cite.</h2>
      </div>
      <div class="grid-2">
        {functions.map((f) => (
          <div class="card">
            <span class="eyebrow"><span class="ix">{f.n}</span></span>
            <h3>{f.h}</h3>
            <p>{f.p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. How Zicy operationalises it -->
  <section style="background:var(--lavender)">
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">03</span> How Zicy operationalises it</span>
        <h2>The practice, in the platform.</h2>
      </div>
      <div class="grid-2">
        {modules.map((m) => (
          <div class="card">
            <span class="eyebrow">{m.fn}</span>
            <h3>{m.name}</h3>
            <p>{m.desc}</p>
          </div>
        ))}
      </div>
      <p style="margin-top:24px">
        <a class="btn btn-t" href="/platform">See the full platform &rarr;</a>
        <a class="btn btn-t" href="/solutions/brands">For brands &rarr;</a>
      </p>
    </div>
  </section>

  <!-- 5. How Growth.pro applies it -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">04</span> How Growth.pro applies it</span>
        <h2>The source engineering, run for you.</h2>
      </div>
      <div style="max-width:760px">
        <p class="lead" style="font-size:18px">
          Growth.pro applies the full AICE practice in done-for-you programmes, including source-trail
          engineering, earned-citation strategy, and authority-building that goes beyond what a
          self-serve platform can execute. The Zicy platform handles the technical and content layer.
        </p>
        <div class="cta-row" style="margin-top:24px">
          <a class="btn btn-o" href="/done-for-you">Explore done-for-you</a>
          <a class="btn btn-t" href="https://www.growth.pro/" target="_blank" rel="noopener noreferrer">Growth.pro &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. FAQ -->
  <section style="background:var(--lavender)">
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow">FAQ</span>
        <h2>Questions about AI Citation Enablement.</h2>
      </div>
      <FaqAccordion items={faqs} defaultOpen={0} />
    </div>
  </section>

  <!-- 7. CTAs -->
  <section class="final">
    <div class="wrap">
      <h2>Make your brand easy to cite.</h2>
      <p>See where AI cites you, and where it paraphrases you without credit, across all five engines.</p>
      <div class="hcta">
        <a class="btn btn-p" href="https://app.zicy.com/register">Try Zicy free</a>
        <a class="btn btn-o" href="/done-for-you">Explore done-for-you</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Breadcrumb: tokens only, no hardcoded hex. */
  .crumbs{display:flex;flex-wrap:wrap;align-items:center;gap:8px;font-size:13px;color:var(--muted);margin-bottom:18px}
  .crumbs a{color:var(--muted)}
  .crumbs a:hover{color:var(--indigo)}
  .crumbs .sep{color:var(--line-2)}
  .crumbs .here{color:var(--ink)}

  .pill{
    display:inline-block;margin-bottom:16px;padding:6px 14px;border-radius:999px;
    background:var(--lavender);border:0.5px solid var(--line);
    font-family:var(--mono);font-size:11.5px;letter-spacing:.06em;text-transform:uppercase;
    color:var(--indigo);font-weight:500;
  }

  .def{font-family:var(--display);font-size:clamp(20px,2.4vw,26px);line-height:1.45;color:var(--ink);max-width:820px;letter-spacing:-0.01em}
</style>
