---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import { SITE } from '../../data/site';

const title = "The AI Visibility Operating System, Growth.pro's operating model";
const description =
  "The AI Visibility Operating System is Growth.pro's full operating model for building, measuring, and sustaining a brand's presence in AI-generated answers, across five pillars: Strategy, Measurement, Execution, Reporting, and Governance.";

const url = `${SITE.url}/about/ai-visibility-operating-system`;
const name = 'The AI Visibility Operating System';
const datePublished = '2026-06-19';
const definition =
  "The AI Visibility Operating System is Growth.pro's full operating model for building, measuring, and sustaining a brand's presence in AI-generated answers, structured across five pillars: Strategy, Measurement, Execution, Reporting, and Governance.";

// How it works: the five pillars.
const pillars = [
  {
    n: '01',
    h: 'Strategy',
    p: "Defining the brand's AI visibility objectives, the query set that matters, the engines to prioritise, and the competitive baseline. Where PAVA diagnostics feed in.",
  },
  {
    n: '02',
    h: 'Measurement',
    p: "Systematic tracking of mention coverage, citation rate, share of voice, average AI ranking, and AI Reality Score across the tracked prompt set and all five engines. This is the pillar Zicy's platform operationalises most directly.",
  },
  {
    n: '03',
    h: 'Execution',
    p: 'The technical and content work that improves the measurement numbers: schema, llms.txt, content creation, entity gap remediation, citation source engineering.',
  },
  {
    n: '04',
    h: 'Reporting',
    p: 'Structured, recurring proof of what changed and why, from AI visibility metrics through to GA4 and Search Console demand signals. The proof layer.',
  },
  {
    n: '05',
    h: 'Governance',
    p: 'The processes, accountabilities, and review cadences that keep AI visibility work sustained and consistent over time, not a one-off project but an ongoing programme.',
  },
];

// How Zicy operationalises it: Measurement and Execution most directly, plus Reporting.
const modules = [
  {
    stage: 'Measurement',
    name: 'AI Visibility, Brand Intelligence, AI Reality Score, Citation Analysis, Competitive AI Performance, Prompt Manager',
    desc: 'The tracking layer: mention coverage, citation rate, share of voice, average ranking and accuracy across the tracked prompt set and all five engines.',
  },
  {
    stage: 'Execution',
    name: 'Action Center, Content Generator, Content Optimizer',
    desc: 'The work that moves the numbers: schema and llms.txt, new citation-worthy content, and upgrades to existing content.',
  },
  {
    stage: 'Reporting',
    name: 'Site Traffic',
    desc: 'AI-referred sessions with GA4 and Search Console, the proof layer that ties visibility back to demand.',
  },
];

const faqs = [
  {
    q: 'What is the AI Visibility Operating System?',
    a: "The AI Visibility Operating System is Growth.pro's complete operating model for AI visibility, covering Strategy, Measurement, Execution, Reporting, and Governance. It is the framework behind Growth.pro's managed programmes and the architecture Zicy's platform implements in the Measurement and Execution pillars.",
  },
  {
    q: 'Who created the AI Visibility Operating System?',
    a: "Growth.pro created and owns the AI Visibility Operating System. Zicy, the platform built by Growth.pro, operationalises its Measurement and Execution pillars in software.",
  },
  {
    q: 'How is it different from an SEO strategy?',
    a: 'An SEO strategy targets search-engine rankings. The AI Visibility Operating System targets presence and accuracy inside AI-generated answers, a different set of signals, engines, and outcomes, requiring a different measurement model, a different execution toolkit, and a different proof layer.',
  },
  {
    q: 'Does Zicy implement the full Operating System?',
    a: 'Zicy operationalises the Measurement and Execution pillars: tracking, diagnosis, content, schema, and proof. The Strategy and Governance pillars require the kind of expert configuration and ongoing oversight that Growth.pro provides in its done-for-you programmes.',
  },
  {
    q: 'How long does it take to run the Operating System?',
    a: "Measurement and initial execution work can begin within days using Zicy's platform. A full five-pillar programme, including strategy setting and governance design, typically runs over a 90-day initial engagement with Growth.pro before moving into a recurring operating cadence.",
  },
];

const faqMain = faqs.map((f) => ({
  '@type': 'Question',
  name: f.q,
  acceptedAnswer: { '@type': 'Answer', text: f.a },
}));

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: 'About', item: `${SITE.url}/about` },
    { '@type': 'ListItem', position: 3, name, item: url },
  ],
};

const articleGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'TechArticle',
      '@id': `${url}#article`,
      name,
      headline: name,
      description: definition,
      url,
      inLanguage: 'en',
      datePublished,
      author: { '@type': 'Organization', name: 'Growth.pro', url: 'https://www.growth.pro/' },
      publisher: { '@id': `${SITE.url}/#org` },
      mainEntityOfPage: url,
      about: { '@id': `${url}#term` },
    },
    {
      '@type': 'DefinedTerm',
      '@id': `${url}#term`,
      name: 'AI Visibility Operating System',
      description: definition,
      inDefinedTermSet: {
        '@type': 'DefinedTermSet',
        name: 'Growth.pro AI Visibility Frameworks',
        url: `${SITE.url}/about`,
      },
    },
  ],
};

const faqPage = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqMain,
};
---
<BaseLayout title={title} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleGraph)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqPage)} />

  <!-- 1. Hero -->
  <section class="hero inner">
    <div class="wrap">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="sep" aria-hidden="true">&rsaquo;</span>
        <a href="/about">About</a>
        <span class="sep" aria-hidden="true">&rsaquo;</span>
        <span class="here" aria-current="page">{name}</span>
      </nav>
      <span class="pill">Growth.pro framework &middot; operationalised by Zicy</span>
      <h1>{name}</h1>
      <p class="def">{definition}</p>
    </div>
  </section>

  <!-- 2. Why it matters -->
  <section style="background:var(--lavender)">
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">01</span> Why it matters</span>
        <h2>AI visibility is an operation, not a project.</h2>
      </div>
      <div style="max-width:760px">
        <p class="lead" style="font-size:18px">
          AI visibility has no finish line. The engines update, competitors move, and a position you
          won last quarter can quietly erode. A campaign with an end date cannot hold ground that
          keeps shifting.
        </p>
        <p style="margin-top:16px">
          An operating system treats it as an ongoing programme: a strategy to aim the work, a
          measurement layer to read it, execution to move it, reporting to prove it, and governance to
          keep it consistent. The strategy pillar is where the
          <a href="/about/pava-framework">PAVA Framework</a> diagnostics feed in.
        </p>
        <p style="margin-top:16px">
          It is one of <a href="/about">Growth.pro&rsquo;s frameworks</a>, operationalised by Zicy.
          See documented outcomes on <a href="/case-studies">our case studies</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- 3. How it works -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">02</span> How it works</span>
        <h2>Five pillars, run as one.</h2>
      </div>
      <div class="grid-3">
        {pillars.map((p) => (
          <div class="card">
            <span class="eyebrow"><span class="ix">{p.n}</span></span>
            <h3>{p.h}</h3>
            <p>{p.p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. How Zicy operationalises it -->
  <section style="background:var(--lavender)">
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">03</span> How Zicy operationalises it</span>
        <h2>Zicy runs the Measurement and Execution pillars.</h2>
      </div>
      <div class="grid-3">
        {modules.map((m) => (
          <div class="card">
            <span class="eyebrow">{m.stage}</span>
            <h3>{m.name}</h3>
            <p>{m.desc}</p>
          </div>
        ))}
      </div>
      <p style="max-width:760px;margin-top:20px">
        Strategy and Governance are where Growth.pro&rsquo;s team adds the operating layer around the
        platform. <a href="/platform">See the full platform &rarr;</a>
      </p>
    </div>
  </section>

  <!-- 5. How Growth.pro applies it -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">04</span> How Growth.pro applies it</span>
        <h2>The full operating system, run for you.</h2>
      </div>
      <div style="max-width:760px">
        <p class="lead" style="font-size:18px">
          Growth.pro runs the full five-pillar Operating System in done-for-you programmes, including
          Strategy and Governance, which require human expertise to configure correctly. The Zicy
          platform gives you the Measurement and Execution pillars self-serve.
        </p>
        <div class="cta-row" style="margin-top:24px">
          <a class="btn btn-o" href="/done-for-you">Explore done-for-you</a>
          <a class="btn btn-t" href="https://www.growth.pro/" target="_blank" rel="noopener noreferrer">Growth.pro &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. FAQ -->
  <section style="background:var(--lavender)">
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow">FAQ</span>
        <h2>Questions about the operating system.</h2>
      </div>
      <FaqAccordion items={faqs} defaultOpen={0} />
    </div>
  </section>

  <!-- 7. CTAs -->
  <section class="final">
    <div class="wrap">
      <h2>Run AI visibility as an operation.</h2>
      <p>Start with the measurement and execution pillars across all five engines.</p>
      <div class="hcta">
        <a class="btn btn-p" href="https://app.zicy.com/register">Try Zicy free</a>
        <a class="btn btn-o" href="/done-for-you">Explore done-for-you</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Breadcrumb: tokens only, no hardcoded hex. */
  .crumbs{display:flex;flex-wrap:wrap;align-items:center;gap:8px;font-size:13px;color:var(--muted);margin-bottom:18px}
  .crumbs a{color:var(--muted)}
  .crumbs a:hover{color:var(--indigo)}
  .crumbs .sep{color:var(--line-2)}
  .crumbs .here{color:var(--ink)}

  .pill{
    display:inline-block;margin-bottom:16px;padding:6px 14px;border-radius:999px;
    background:var(--lavender);border:0.5px solid var(--line);
    font-family:var(--mono);font-size:11.5px;letter-spacing:.06em;text-transform:uppercase;
    color:var(--indigo);font-weight:500;
  }

  .def{font-family:var(--display);font-size:clamp(20px,2.4vw,26px);line-height:1.45;color:var(--ink);max-width:820px;letter-spacing:-0.01em}
</style>
