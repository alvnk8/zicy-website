---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';

const title = 'About Zicy — the story of Growth.pro, reborn as AI';
const description =
  "Zicy is the AI growth co-pilot built by Growth.pro — an AEO/GEO/SEO assistant that scales agency-grade expertise to every business, from solopreneur to enterprise.";

// 'That decision gave birth to Zicy' — the four components described in the founder story.
const components = [
  {
    h: 'A DIY AI Growth Co-Pilot',
    p: 'Powered by a highly-intelligent AEO/GEO/SEO chat-based bot.',
  },
  {
    h: 'A butler service for digital growth',
    p: 'Talk to it in plain human language and get expert consultations instantly.',
  },
  {
    h: 'AI citations & rankings, engineered',
    p: 'A system that does more than SEO tasks — it engineers AI citations and rankings for the new era of search.',
  },
  {
    h: 'For everyone — from solopreneur to enterprise',
    p: 'Solopreneur, small ecommerce shop, in-house marketing team, or enterprise — Zicy was designed to serve them all, with the same values Growth.pro has always stood for.',
  },
];

const team = [
  {
    name: 'Alvin Koay',
    role: 'Founder',
    bio: "Started Growth.pro before the pandemic and saw an SEO industry riddled with broken promises. Built Zicy to clone Growth.pro's ethos — empathy, trust, accountability, transparency, and integrity — into AI, so even the smallest businesses get fair access to world-class strategies.",
  },
  {
    name: 'April Cheong',
    role: 'Co-founder',
    bio: "April excels at the intersection of data, strategy, and artificial intelligence — translating complex analytics into actionable business insights. At Zicy, April's expertise in Big Data architecture, AI-powered product ideation, and workflow automation shapes our intelligent, user-focused approach to Answer Engine Optimisation.",
  },
  {
    name: 'Ritu Khanna',
    role: 'Co-founder',
    bio: 'Over 15 years in the corporate sector leading environmental-industry projects, plus a decade in SEO strategy and content planning. At Zicy, Ritu applies that experience to develop practical AI-first optimisation methods that help businesses become visible in AI-generated answers.',
  },
  {
    name: 'Peter Kua',
    role: 'Chief Data Officer',
    bio: "A distinguished data science strategist who led Data Science & Analytics at REV Media Group and drove Malaysia's National Big Data Analytics Initiative under MDEC — developing the country's first National BDA Framework. Has trained senior teams at Citibank, Intel, Dell, NTT Data, Maxis and Johnson & Johnson.",
  },
];
---
<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <section class="hero inner">
    <div class="wrap">
      <span class="eyebrow">About</span>
      <h1>The story behind Zicy.</h1>
      <p class="lead">
        From an SEO agency built on broken promises to an AI co-pilot built on Growth.pro's values —
        empathy, trust, accountability, transparency, and integrity. This is how it started, and why
        it exists.
      </p>
    </div>
  </section>

  <!-- The founder narrative -->
  <section>
    <div class="wrap">
      <div class="prose">
        <p>
          Before the COVID-19 pandemic, our founder <b>Alvin Koay</b> started Growth.pro: a
          full-blown SEO agency. The agency quickly grew into a trusted partner for international
          brands, but Alvin couldn't shake what he had long observed: the SEO industry was riddled
          with broken promises.
        </p>
        <p>
          He saw too many small businesses — mom-and-pop shops, solopreneurs, ecommerce founders —
          being tied down by contracts, misled with jargon, and handed reports that looked
          impressive but delivered no real outcomes. Agencies often maximised their retainers while
          their clients stayed invisible online. Alvin himself had felt the sting of being an
          underdog in business, and this struck a nerve.
        </p>
        <p>
          The challenge was clear: how could Growth.pro's values — empathy, trust, accountability,
          transparency, and integrity — be scaled beyond a service agency, so even the smallest
          businesses could access world-class strategies without being exploited?
        </p>
        <p>
          Alvin's desire was simple yet ambitious: to create a solution that democratised SEO, AEO,
          and GEO. A solution that anyone — regardless of company size or budget — could use to
          compete fairly against giants.
        </p>
        <p>
          Instead of building more human-heavy agency layers, Alvin and his team decided to clone
          Growth.pro's ethos and expertise into AI itself. The idea was not to build another agency
          tool, but a highly intelligent co-pilot that worked as a conversational "butler" for
          digital growth.
        </p>
      </div>
    </div>
  </section>

  <!-- That decision gave birth to Zicy -->
  <section style="background:var(--lavender)">
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow">That decision gave birth to Zicy</span>
        <h2>One co-pilot, built for everyone.</h2>
      </div>
      <div class="grid-2">
        {components.map((c) => (
          <div class="card"><h3>{c.h}</h3><p>{c.p}</p></div>
        ))}
      </div>
    </div>
  </section>

  <!-- Epiphany pull-quote + closing narrative -->
  <section>
    <div class="wrap">
      <div style="max-width:720px">
        <span class="eyebrow">Epiphany</span>
        <p class="pullquote" style="font-size:26px;margin:18px 0 30px">
          In the AI era, businesses no longer need to gamble on agencies or contracts. With Zicy,
          their growth partner can live inside AI itself — empathetic, transparent, and on their
          side.
        </p>
        <p style="font-size:17px;color:#3a3950;margin-bottom:20px">
          Zicy is the true personification of Growth.pro: Alvin Koay's heart, beliefs, and
          relentless fight for fairness, coded into AI. It exists so that the underdogs — those
          who have always been overlooked — finally have a co-pilot to help them get seen, trusted,
          and chosen in the age of AI-driven search.
        </p>
        <p style="font-size:19px;font-weight:600;color:var(--indigo);font-family:var(--display);line-height:1.35;margin-top:14px">
          Zicy isn't just software. It's Growth.pro's story of resilience, empathy, and integrity —
          reborn as AI.
        </p>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section style="background:var(--lavender)">
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow">Team</span>
        <h2>Meet our team.</h2>
        <p>APAC-native, globally capable — built in Penang, Malaysia.</p>
      </div>
      <div class="grid-2">
        {team.map((m) => (
          <div class="card">
            <h3 style="margin-bottom:4px">{m.name}</h3>
            <p class="mono" style="font-size:12.5px;color:var(--orange);letter-spacing:.08em;text-transform:uppercase;margin-bottom:14px">{m.role}</p>
            <p>{m.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Promise -->
  <section>
    <div class="wrap">
      <div class="shead"><span class="eyebrow">Our promise</span><h2>Clarity, speed, outcomes.</h2></div>
      <div style="max-width:720px">
        <p class="lead" style="font-size:18px;margin-bottom:18px">
          Whether you're a solo marketer or a global marketing team, Zicy is designed to fit into
          your workflow and give you one clear answer to the question:
        </p>
        <p class="pullquote" style="font-size:24px;margin:0 0 26px">
          "What's stopping us from being the answer — and how do we fix it?"
        </p>
        <p style="font-size:17px;color:#3a3950">We're not just building a product.</p>
        <p style="font-size:21px;font-weight:600;color:var(--indigo);font-family:var(--display);margin-top:6px">
          We're building the future of search strategy.
        </p>
      </div>
    </div>
  </section>

  <CtaBand
    eyebrow="Ready to see what AI says about you?"
    heading="See your brand the way AI describes it."
    ctaLabel="Run a free audit"
    ctaHref="/audit"
  />
</BaseLayout>
