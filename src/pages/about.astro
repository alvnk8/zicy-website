---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import alvinPhoto from '../assets/team/alvin-koay.png';
import aprilPhoto from '../assets/team/april-cheong.png';
import rituPhoto from '../assets/team/ritu-khanna.png';
import peterPhoto from '../assets/team/peter-kua.jpg';

const title = 'About Zicy, the truth layer for AI visibility';
const description =
  "Zicy is the AI visibility platform built by Growth.pro. Meet the team and the mission: measure how AI describes your brand, fix what's wrong, and prove it.";

const beliefs = [
  {
    h: 'Truth over noise.',
    p: 'Knowing whether AI is right about you matters more than knowing you were mentioned.',
  },
  {
    h: 'Earned, not gamed.',
    p: 'Visibility that lasts comes from genuine expertise made easy for AI to find, not from working against the system.',
  },
  {
    h: 'Proof, not vanity.',
    p: "The work has to connect to real demand, or it doesn't count.",
  },
];

// Team — bios verbatim from the live site (zicy.com/about) where they exist.
// Alvin's bio is condensed from the founder narrative for parity with the other three cards.
const team = [
  {
    name: 'Alvin Koay',
    role: 'Founder & CEO',
    photo: alvinPhoto,
    alt: 'Alvin Koay, Founder and CEO of Zicy',
    bio: "Started Growth.pro before the pandemic and saw an SEO industry riddled with broken promises. Built Zicy to clone Growth.pro's ethos, empathy, trust, accountability, transparency and integrity, into AI, so even the smallest businesses get fair access to world-class strategies.",
  },
  {
    name: 'April Cheong',
    role: 'Co-founder',
    photo: aprilPhoto,
    alt: 'April Cheong, Co-founder of Zicy',
    bio: 'April excels at the intersection of data, strategy and artificial intelligence, translating complex analytics into actionable business insights. At Zicy, April\'s expertise in Big Data architecture, AI-powered product ideation and workflow automation shapes our intelligent, user-focused approach to Answer Engine Optimisation.',
  },
  {
    name: 'Ritu Khanna',
    role: 'Co-founder',
    photo: rituPhoto,
    alt: 'Ritu Khanna, Co-founder of Zicy',
    bio: 'Over 15 years in the corporate sector leading environmental-industry projects, plus a decade in SEO strategy and content planning. At Zicy, Ritu applies that experience to develop practical AI-first optimisation methods that help businesses become visible in AI-generated answers.',
  },
  {
    name: 'Peter Kua',
    role: 'Chief Data Officer',
    photo: peterPhoto,
    alt: 'Peter Kua, Chief Data Officer of Zicy',
    bio: "A distinguished data science strategist who led Data Science & Analytics at REV Media Group and drove Malaysia's National Big Data Analytics Initiative under MDEC, developing the country's first National BDA Framework. Has trained senior teams at Citibank, Intel, Dell, NTT Data, Maxis and Johnson & Johnson.",
  },
];
---
<BaseLayout title={title} description={description}>
  <!-- Hero (white) -->
  <section class="hero inner">
    <div class="wrap">
      <span class="eyebrow">About</span>
      <p class="pullquote">The answer&rsquo;s already written. Make sure you&rsquo;re in it.</p>
      <h1>We built the truth layer for AI visibility.</h1>
      <p class="lead">
        Zicy exists because brands are being described by AI every day, and most have no idea what
        it's saying. We measure it, help fix it, and prove the fix worked.
      </p>
    </div>
  </section>

  <!-- Where Zicy came from (lavender) -->
  <section style="background:var(--lavender)">
    <div class="wrap">
      <div class="shead"><span class="eyebrow"><span class="ix">01</span> Where Zicy came from</span><h2>An agency story, scaled into AI.</h2></div>
      <div class="prose" style="max-width:760px">
        <p>
          Before the pandemic, founder <b>Alvin Koay</b> started Growth.pro, a full SEO agency that
          grew into a trusted partner for international brands. But he couldn't shake what he'd long
          observed: too many small businesses tied down by contracts, misled with jargon and handed
          reports that looked impressive yet delivered no real outcomes. Agencies maximised their
          retainers while the clients stayed invisible online.
        </p>
        <p>
          So instead of building more human-heavy agency layers, Alvin and his team cloned
          Growth.pro's ethos (empathy, trust, accountability, transparency and integrity) into AI
          itself. The result is Zicy: a measurement and remediation platform that scales agency-grade
          AI visibility to anyone, from solopreneur to enterprise, with the same values the
          consultancy has always stood for.
        </p>
      </div>
    </div>
  </section>

  <!-- Zicy & Growth.pro (white). §A2 — Growth.pro IP named, attributed, never described as engineering. -->
  <section>
    <div class="wrap">
      <div class="shead"><span class="eyebrow"><span class="ix">02</span> Zicy &amp; Growth.pro</span><h2>The platform, and the consultancy that built it.</h2></div>
      <div style="max-width:760px">
        <p class="lead" style="font-size:18px">
          Zicy is the platform. Growth.pro is the consultancy that built it and uses it to run
          done-for-you programmes for enterprise brands. The platform is open to everyone; the
          managed service is selective. The frameworks behind that service, the
          <b>AI Visibility Operating System</b>, the <b>PAVA Framework</b> and the
          <b>AI Citation Enablement</b> practice, are Growth.pro's.
        </p>
        <ul class="fw-links">
          <li>
            <a href="/about/pava-framework">PAVA Framework</a>
            <span>Presence, Authority, Visibility, Amplification, the diagnostic framework for AI visibility.</span>
          </li>
          <li>
            <a href="/about/ai-visibility-operating-system">AI Visibility Operating System</a>
            <span>The five-pillar operating model: strategy, measurement, execution, reporting, governance.</span>
          </li>
          <li>
            <a href="/about/ai-citation-enablement">AI Citation Enablement</a>
            <span>The citation and source-engineering practice that makes a brand citable by AI.</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- APAC-native, globally capable (lavender) -->
  <section style="background:var(--lavender)">
    <div class="wrap">
      <div class="shead"><span class="eyebrow"><span class="ix">03</span> APAC-native, globally capable</span><h2>Built in Penang. Covering every engine, every language.</h2></div>
      <div style="max-width:760px">
        <p class="lead" style="font-size:18px;margin-bottom:14px">
          Built in Penang, covering every engine and every language. The multi-language,
          multi-market coverage that US-built tools treat as an afterthought is our starting point.
        </p>
        <p class="mono" style="font-size:13px;color:var(--muted);letter-spacing:.04em">
          Growth Pro Sdn. Bhd. operates under <b>Malaysia Digital (MD)</b> status, Malaysia's
          national designation for digital-economy companies.
        </p>
      </div>
    </div>
  </section>

  <!-- What we believe (white) -->
  <section>
    <div class="wrap">
      <div class="shead"><span class="eyebrow"><span class="ix">04</span> What we believe</span><h2>Three commitments.</h2></div>
      <div class="grid-3">
        {beliefs.map((b) => (
          <div class="card"><h3>{b.h}</h3><p>{b.p}</p></div>
        ))}
      </div>
    </div>
  </section>

  <!-- Meet the team (lavender). 2-up on desktop, 1-up on mobile. -->
  <section style="background:var(--lavender)">
    <div class="wrap">
      <div class="shead"><span class="eyebrow"><span class="ix">05</span> Meet the team</span><h2>The people behind Zicy.</h2></div>
      <div class="team-grid">
        {team.map((m) => (
          <article class="team-card">
            <Image
              src={m.photo}
              alt={m.alt}
              widths={[200, 320, 480]}
              sizes="(max-width: 860px) 140px, 180px"
              class="team-photo"
              loading="lazy"
            />
            <div class="team-text">
              <h3>{m.name}</h3>
              <p class="team-role">{m.role}</p>
              <p class="team-bio">{m.bio}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Our promise + CTAs (white) -->
  <section>
    <div class="wrap">
      <div class="shead"><span class="eyebrow"><span class="ix">06</span> Our promise</span><h2>Clarity, speed, outcomes.</h2></div>
      <div style="max-width:720px">
        <p class="lead" style="font-size:18px;margin-bottom:28px">
          Whether you're a solo marketer or a global marketing team, Zicy is designed to give you
          one clear answer to one clear question:
          <i>"What's stopping us from being the answer, and how do we fix it?"</i>
        </p>
        <div class="cta-row">
          <a class="btn btn-primary btn-lg" href="https://app.zicy.com/register">Try for free</a>
          <a class="btn btn-ghost btn-lg" href="/platform">See the platform</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Framework links in §02 — three Growth.pro framework pages. Tokens only. */
  .fw-links{list-style:none;margin:22px 0 0;padding:0;display:grid;gap:12px;max-width:760px}
  .fw-links li{padding:16px 18px;background:var(--lavender);border:0.5px solid var(--line);border-radius:12px}
  .fw-links a{font-family:var(--display);font-weight:600;color:var(--indigo);font-size:17px;letter-spacing:-0.01em}
  .fw-links a:hover{color:var(--indigo-bright)}
  .fw-links span{display:block;margin-top:4px;font-size:14px;color:#4a4960;line-height:1.55}

  /* Team grid — 2-up on desktop, 1-up on mobile. */
  .team-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}
  .team-card{
    display:flex;gap:22px;align-items:flex-start;
    background:#fff;border:0.5px solid var(--line);border-radius:14px;padding:24px;
  }
  .team-photo{
    flex:0 0 auto;
    width:140px;height:140px;
    border-radius:50%;
    object-fit:cover;
    border:1px solid var(--line-2);
    background:#fafaff;
  }
  .team-text{flex:1 1 auto;min-width:0}
  .team-text h3{font-family:var(--display);font-size:22px;color:var(--indigo);margin-bottom:2px;letter-spacing:-0.01em}
  .team-role{
    font-family:var(--mono);font-size:11.5px;letter-spacing:.12em;text-transform:uppercase;
    color:var(--orange);margin-bottom:12px;font-weight:500;
  }
  .team-bio{font-size:14.5px;color:#4a4960;line-height:1.6}

  @media (max-width: 860px){
    .team-grid{grid-template-columns:1fr;gap:18px}
    .team-card{flex-direction:column;align-items:center;text-align:center;padding:26px 22px}
    .team-photo{width:120px;height:120px}
  }
</style>
