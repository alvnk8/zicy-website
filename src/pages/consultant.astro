---
import BaseLayout from '../layouts/BaseLayout.astro';
import Consultant from '../components/Consultant.astro';

const title = 'Zicy AEO/GEO Consultant: ask anything about AI search visibility';
const description =
  'A free AI consultant for AEO and GEO. Audit a page or ask how to get cited in ChatGPT, Gemini and Perplexity, powered by Growth.pro’s proprietary framework.';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.zicy.com/' },
    { '@type': 'ListItem', position: 2, name: 'Free tools', item: 'https://www.zicy.com/free-tools' },
    { '@type': 'ListItem', position: 3, name: 'AEO/GEO Consultant', item: 'https://www.zicy.com/consultant' },
  ],
};
---
<BaseLayout title={title} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumb)} />
  <Consultant />
</BaseLayout>
