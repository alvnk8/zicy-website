---
import BaseLayout from '../layouts/BaseLayout.astro';
import FreeDiagnostic from '../components/FreeDiagnostic.astro';

const title = 'Free AI reality score: see how AI describes your brand';
const description =
  'Enter your brand name and website. Zicy checks how ChatGPT, Gemini, Perplexity, Google AI Overviews and Google AI Mode describe your brand against the facts, free.';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.zicy.com/' },
    { '@type': 'ListItem', position: 2, name: 'Free tools', item: 'https://www.zicy.com/free-tools' },
    { '@type': 'ListItem', position: 3, name: 'Free diagnostic', item: 'https://www.zicy.com/free-diagnostic' },
  ],
};
---
<BaseLayout title={title} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumb)} />
  <FreeDiagnostic />
</BaseLayout>
