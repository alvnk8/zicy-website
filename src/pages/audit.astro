---
import BaseLayout from '../layouts/BaseLayout.astro';

// The free audit is temporarily paused. The page stays up as a placeholder
// so that the ~10 "Run a free audit" CTAs across the rest of the site still
// resolve, instead of 404-ing. Restore by reverting this commit.

const title = 'Audit currently paused — Zicy';
const description =
  "Zicy's free AI visibility audit is temporarily paused. Check back shortly, or explore the platform and pricing in the meantime.";
---
<BaseLayout title={title} description={description} noindex={true}>
  <section class="hero inner">
    <div class="wrap">
      <span class="eyebrow">Audit</span>
      <h1>Free audit currently paused.</h1>
      <p class="lead">
        We&rsquo;ve temporarily paused new audit requests while we refresh the programme. Check back
        shortly, or explore the platform in the meantime.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary btn-lg" href="/platform">See the platform</a>
        <a class="btn btn-ghost btn-lg" href="/pricing">See pricing</a>
      </div>
    </div>
  </section>
</BaseLayout>
