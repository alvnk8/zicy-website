---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Screenshot from '../../components/Screenshot.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import FaqUniversal from '../../components/FaqUniversal.astro';
import { brandsFaqs, faqPageJsonLd } from '../../data/faqs';
// No-chrome product exports — topbar + content only, no left module-nav rail or in-frame
// Zicy logo. Demo brand "Acme Pickleball Fashion" is illustrative, not a real client.
import brandIntelligenceShot from '../../assets/screenshots/brand-intelligence-report.png';
import competitiveShot from '../../assets/screenshots/competitive-ai-performance.png';
// Proof-layer screenshot — Site Traffic, Search Console view (shared with /platform and the
// homepage). Canon-clean: shows answer-intent queries + branded-search behaviour, no uplift %.
import siteTraffic from '../../assets/screenshots/site-traffic-search-console.png';

const title = "Zicy for brands — what AI says about your brand, whether it's accurate, and how to fix it";
const description =
  "See what AI says about your brand across ChatGPT, Gemini, Perplexity, Google AI Overview and Google AI Mode — whether it's accurate, how to fix what's wrong, and how the fix ties back to demand. Try Zicy free for 7 days.";

// Sourced stats — every figure carries publisher + sample + year inline. Do not alter.
const stakeStats = [
  {
    n: '62%',
    label: 'of Google AI Overview citations come from pages outside the top 10 results.',
    source: 'Ahrefs, 863,000 keywords / 4M AI Overview URLs, 2026 (detection method improved; not directly comparable to Ahrefs’ 2025 figure).',
  },
  {
    n: '62%',
    label: 'of consumers trust AI tools to guide their brand decisions.',
    source: 'Yext / Researchscape, n=2,237, 2025',
  },
  {
    n: '12%',
    label: 'of AI-cited links also rank in Google’s top 10 — SEO is not AI visibility.',
    source: 'Ahrefs, 15,000 prompts, 2025',
  },
];

const usps = [
  {
    h: 'Truth, not just mentions.',
    p: 'Most trackers tell you whether you were named. Zicy tells you whether what AI said was true — the AI Reality Score flags hallucinations, outdated claims and wrong facts before a buyer ever sees them.',
  },
  {
    h: 'Every engine, every language.',
    p: 'APAC-native coverage across all five engines and the languages your buyers use — not English-first with everything else an afterthought.',
  },
  {
    h: 'The whole loop, not just the scoreboard.',
    p: 'Measure, then diagnose the cause, then act — schema, llms.txt, content — then prove it moved demand. Other tools hand you a dashboard and stop.',
  },
];

const wiifm = [
  'Catch a hallucination or an outdated claim before it costs you a deal.',
  'Know exactly where a competitor is winning the answer, and why.',
  'One board-ready number — your AI share of voice, tracked over time.',
  'Start every quarter knowing what AI says about you, not hoping.',
];

const modules = [
  {
    name: 'Brand Intelligence',
    desc: 'How AI describes you, the AI Reality Score, the entity gaps behind low confidence, and a prioritised action plan.',
  },
  {
    name: 'AI Visibility',
    desc: 'Mention coverage, citation rate, share of voice and average ranking, against the competitors you actually worry about.',
  },
  {
    name: 'Brand Sentiment',
    desc: 'The language AI attaches to your brand, and the sources moving it.',
  },
  {
    name: 'Action Center',
    desc: 'Schema and llms.txt generators, content fixes, built to current best practice.',
  },
  {
    name: 'Site Traffic',
    desc: 'AI-referred sessions and downstream engagement, tied back to the work.',
  },
];

// FAQ — page-specific block (6) from src/data/faqs.ts; the universal block renders beneath it
// via <FaqUniversal />. JSON-LD = brands specific + universal, matching the visible answers.
const faqPage = faqPageJsonLd(brandsFaqs);
---
<BaseLayout title={title} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqPage)} />

  <!-- 1. Hero -->
  <section class="hero inner">
    <div class="wrap">
      <span class="eyebrow">For brands</span>
      <h1>AI is your brand&rsquo;s new first impression. Make it the one you built.</h1>
      <p class="lead">
        Every day, buyers, partners and journalists ask AI about your category and act on the
        answer before they ever reach your site. Zicy shows you what AI says about you across all
        five major engines, whether it&rsquo;s accurate, and how to fix what&rsquo;s wrong &mdash;
        then ties the fix back to demand.
      </p>
      <div class="cta-row">
        <a class="btn btn-p btn-lg" href="https://app.zicy.com/register">Try for free</a>
        <a class="btn btn-o btn-lg" href="/platform">See the platform</a>
      </div>
    </div>
  </section>

  <!-- 2. 01 · The risk — three sourced stats -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">01</span> The risk</span>
        <h2>You can&rsquo;t manage what you can&rsquo;t see — and you can&rsquo;t see this in your analytics.</h2>
        <p>
          When AI misdescribes you, or names a competitor in your place, the decision is shaped
          before anyone reaches your site. It never shows up in your funnel, because the
          conversation never touched it. More than 1 billion people now use generative AI every
          month (Meltwater &amp; We Are Social, Digital 2026).
        </p>
      </div>
      <div class="grid-3">
        {stakeStats.map((s) => (
          <div class="stat">
            <div class="n">{s.n}</div>
            <div class="t">{s.label}</div>
            <div class="s">Source: {s.source}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. 02 · Why brands choose Zicy — three differentiator cards -->
  <section style="background:var(--mist)">
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">02</span> Why brands choose Zicy</span>
        <h2>Competitors measure. Zicy proves.</h2>
      </div>
      <div class="grid-3">
        {usps.map((u) => (
          <div class="card"><h3>{u.h}</h3><p>{u.p}</p></div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. 03 · What you get — outcome bullets -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">03</span> What you get</span>
        <h2>What changes on Monday.</h2>
      </div>
      <ul class="checklist">
        {wiifm.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <!-- 5. 04 · The proof layer (NEW) — capability copy + Site Traffic screenshot, top-aligned -->
  <section style="background:var(--mist)">
    <div class="wrap">
      <div class="feature-split">
        <div class="shead" style="margin-bottom:0">
          <span class="eyebrow"><span class="ix">04</span> The proof layer</span>
          <h2>One number your CFO will accept.</h2>
          <p>
            Does winning the AI answer move demand? Zicy connects AI-referred sessions and
            branded-search behaviour from GA4 and Search Console to the visibility work, so AI
            share of voice stops being a vanity metric and becomes a line you can defend in a
            budget review.
          </p>
        </div>
        <Screenshot
          src={siteTraffic}
          alt="Zicy Site Traffic, Search Console view — answer-intent queries, question impressions and clicks, and branded-search performance (impressions, clicks, average CTR and average position) connected to the AI visibility work."
          caption="Site Traffic — branded-search behaviour and AI-referred demand, connected to the visibility work."
        />
      </div>
    </div>
  </section>

  <!-- 6. 05 · Inside the platform — five module cards + two product shots -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">05</span> Inside the platform</span>
        <h2>The modules that do the work.</h2>
      </div>
      <div class="grid-3">
        {modules.map((m) => (
          <div class="card">
            <span class="eyebrow">Module</span>
            <h3>{m.name}</h3>
            <p>{m.desc}</p>
          </div>
        ))}
      </div>
      <div class="grid-2" style="margin-top:28px">
        <Screenshot
          src={brandIntelligenceShot}
          alt="Zicy Brand Intelligence report showing AI perception of the brand and an AI Reality Score fact-check."
          caption="Brand Intelligence — perception, AI Reality Score and the descriptors moving the answer."
        />
        <Screenshot
          src={competitiveShot}
          alt="Zicy Competitive AI Performance table comparing the brand against rivals on mention coverage, ranking, citations, share of voice and sentiment."
          caption="Competitive AI Performance — your standing against the rivals you actually worry about."
        />
      </div>
    </div>
  </section>

  <!-- 7. 06 · What it looks like when it works — anonymised case + locked disclosure -->
  <section style="background:var(--mist)">
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">06</span> What it looks like when it works</span>
        <h2>From a near-zero baseline to nine in ten AI answers.</h2>
      </div>
      <div style="max-width:760px">
        <div class="stat" style="padding:32px 34px">
          <div class="n" style="color:var(--ok)">90.61%</div>
          <div class="t" style="margin-top:12px">
            AI mention rate &middot; professional services &middot; from a near-zero baseline
          </div>
        </div>
        <p class="disclosure">
          Measurement: AI brand mention and citation rates across tracked category queries on
          ChatGPT, Gemini and Perplexity, via Zicy&rsquo;s measurement infrastructure. Client
          anonymised pending naming permission.
        </p>
      </div>
    </div>
  </section>

  <!-- 8. FAQ — native <details> accordion; answers in static HTML + FAQPage schema -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow">FAQ</span>
        <h2>Questions brands ask.</h2>
      </div>
      <FaqAccordion items={brandsFaqs} defaultOpen={0} />
      <FaqUniversal />
    </div>
  </section>

  <!-- 9. Final CTA -->
  <section class="final">
    <div class="wrap">
      <h2>See your brand the way AI describes it.</h2>
      <p>All five engines, no commitment. Start a 7-day free trial.</p>
      <div class="hcta">
        <a class="btn btn-p" href="https://app.zicy.com/register">Try for free</a>
        <a class="btn btn-o" href="/pricing">See pricing</a>
      </div>
    </div>
  </section>
</BaseLayout>
