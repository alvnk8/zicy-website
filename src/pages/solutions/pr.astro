---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Screenshot from '../../components/Screenshot.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import FaqUniversal from '../../components/FaqUniversal.astro';
import { prFaqs, faqPageJsonLd } from '../../data/faqs';
// No-chrome product exports — topbar + content only, no left module-nav rail or in-frame
// Zicy logo. Demo brand "Acme Pickleball Fashion" is illustrative, not a real client.
// Citation Analysis uses the URL drill-down export (citation-analysis-urls.png), which carries
// CLEAN labels (owned / earned / competitor / uncited; "paraphrased, no credit") — NOT the
// overview export, whose tiles bake in the banned "hijack rate / leaked rate" labels.
import brandIntelligenceShot from '../../assets/screenshots/brand-intelligence-report.png';
import citationShot from '../../assets/screenshots/citation-analysis-urls.png';
import keyTopicsShot from '../../assets/screenshots/key-topics-leaders.png';

const title = 'Zicy for PR and comms teams, prove your earned work moved the AI answer';
const description =
  'When a journalist, analyst or buyer asks ChatGPT, Gemini, Perplexity, Google AI Overviews or Google AI Mode about your client, Zicy measures whether the coverage you earned shaped the answer, and shows which sources to earn next.';

// The shift — four stakes cards. Every figure carries its inline source verbatim, including
// the Ahrefs not-directly-comparable caveat. Do not alter.
const shiftCards = [
  {
    h: 'The audience is already there.',
    p: 'More than 1 billion people now use standalone generative AI tools each month.',
    source: 'Meltwater & We Are Social, Digital 2026, Similarweb',
  },
  {
    h: 'Buyers research inside the chat.',
    p: "45% of B2B buyers used generative AI to research vendors and products in a recent purchase. Earned coverage AI can't see doesn't reach them.",
    source: 'Gartner, n=645 B2B buyers, 2025',
  },
  {
    h: "The cited sources aren't the ranked ones.",
    p: "Only about 38% of Google AI Overviews citations come from pages ranking in the top 10, down from 76% seven months earlier. A ranking report won't tell you which sources AI trusts.",
    source:
      'Ahrefs, 863,000 keywords / 4M URLs, 2026; detection method changed, so not directly comparable to the earlier figure',
  },
  {
    h: 'The licensing map is being redrawn.',
    p: "Publishers are signing AI content deals and suing over uncompensated use at the same time. Which outlets AI actually cites in your client's category is a moving, measurable target, not a fixed media list.",
    source: 'Digiday; Press Gazette, 2025–26',
  },
];

// Module touchpoints — ordered Measure → Diagnose → Act → Prove, per the brief's list.
const modules = [
  {
    name: 'Brand Intelligence: your reputation-risk audit.',
    desc: 'Per-engine view of misaligned sentiment, hallucinations, and not-associated signals across ChatGPT, Gemini, Perplexity, Google AI Overviews, and Google AI Mode. Shows where to concentrate earned media before a campaign, not after.',
  },
  {
    name: 'Key Topics: your narrative-control map.',
    desc: "Splits the category into the topics you lead, the battlegrounds worth contesting, and the blind spots you've ceded. The competitor column shows who AI credits on each story. Battlegrounds and blind spots become the earned-media pitch list you take to your media targets.",
  },
  {
    name: 'Citation Analysis: your earned-media targeting map.',
    desc: 'Which source categories AI cites in the category, broken down owned / earned / competitor / uncited, down to the individual URL. The uncited rate flags where AI paraphrased a source without crediting it. This is where you see competitor share of the narrative and where to win it back.',
  },
  {
    name: 'Competitor Sentiment: the framing each rival is earning.',
    desc: 'The associations AI attaches to each competing brand, and the positive / neutral / negative split. Core comms intelligence for positioning and rapid response.',
  },
  {
    name: 'Prompt Manager: per-engine reputational monitoring.',
    desc: "Track the exact questions that shape your client's reputation, per engine, with the full AI response and the sources it leaned on. Because weighting differs across the five engines, you can target the outlets that move a specific engine, and prove the narrative shifted after you did.",
  },
  {
    name: 'Content Generator: citation-backed thought leadership, fast.',
    desc: 'Turn approved messaging into source-grounded, on-record thought leadership with a research step that makes it genuinely pitchable. Human-reviewed and brand-tone aware; never scaled, anonymous, or fabricated content.',
  },
  {
    name: 'Prove: earned work, answered.',
    desc: 'Connect AI visibility to downstream branded search and on-site engagement, so you can show that an earned campaign moved the AI answer and the demand behind it.',
  },
];

// FAQ — page-specific block (8) from src/data/faqs.ts; the universal block renders beneath it
// via <FaqUniversal />. JSON-LD = PR specific + universal, matching the visible answers.
const faqPage = faqPageJsonLd(prFaqs);
---
<BaseLayout title={title} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqPage)} />

  <!-- 1. Hero -->
  <section class="hero inner">
    <div class="wrap">
      <span class="eyebrow">For PR and comms teams</span>
      <h1>Prove your earned work moved the AI answer.</h1>
      <p class="lead">
        When a journalist, analyst, or buyer asks ChatGPT, Gemini, Perplexity, Google AI Overviews,
        or Google AI Mode about your client, the coverage you earned is either shaping that answer
        or it isn&rsquo;t. Zicy measures which, and shows you which sources to earn next.
      </p>
      <div class="cta-row">
        <a class="btn btn-p btn-lg" href="https://app.zicy.com/register">Try for free</a>
        <a class="btn btn-o btn-lg" href="/platform">See the platform</a>
      </div>
    </div>
  </section>

  <!-- 2. 01 · The shift — four sourced stakes cards -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">01</span> The shift</span>
        <h2>The AI answer is now a primary place your client&rsquo;s reputation is formed.</h2>
        <p>It is measurable, and most comms programmes are not yet measuring it.</p>
      </div>
      <div class="grid-2">
        {shiftCards.map((c) => (
          <div class="card">
            <h3>{c.h}</h3>
            <p>{c.p}</p>
            <div class="mono" style="font-size:11.5px;color:var(--muted);margin-top:14px;letter-spacing:.02em;line-height:1.5">
              Source: {c.source}
            </div>
          </div>
        ))}
      </div>
      <p class="pullquote">The answer&rsquo;s already written. Make sure your client&rsquo;s in it.</p>
    </div>
  </section>

  <!-- 3. 02 · What Zicy does for PR — the brand-side guard, stated plainly -->
  <section style="background:var(--mist)">
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">02</span> What Zicy does</span>
        <h2>We measure the narrative. You earn it.</h2>
      </div>
      <div style="max-width:760px">
        <p class="sub" style="font-size:18px">
          Zicy doesn&rsquo;t pitch journalists or place coverage. Your team does that, on the
          merits of the work. Zicy measures whether the coverage you earned changed what AI says
          about your client: which sources AI cites, how sentiment shifted after a campaign, and
          where a competitor still owns the story.
        </p>
        <p class="sub" style="font-size:18px;margin-top:18px">
          It is the proof layer earned media has never had, a replacement for
          advertising-value-equivalency that measures answer movement instead of column inches.
        </p>
      </div>
    </div>
  </section>

  <!-- 4. 03 · How PR teams use Zicy — seven module touchpoints + three product shots -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">03</span> How PR teams use Zicy</span>
        <h2>Seven touchpoints, in the order the work runs: measure, diagnose, act, prove.</h2>
      </div>
      <div class="grid-3">
        {modules.map((m) => (
          <div class="card">
            <span class="eyebrow">Module</span>
            <h3>{m.name}</h3>
            <p>{m.desc}</p>
          </div>
        ))}
      </div>
      <div class="grid-3" style="margin-top:28px">
        <Screenshot
          src={brandIntelligenceShot}
          alt="Zicy Brand Intelligence, per-engine sentiment, an AI Reality Score fact-check, and entity signals across the five engines."
          caption="Brand Intelligence: your per-engine reputation-risk audit."
        />
        <Screenshot
          src={citationShot}
          alt="Zicy Citation Analysis, the domains and individual URLs AI cites in the category, classified owned, earned, competitor or uncited."
          caption="Citation Analysis: owned / earned / competitor / uncited, down to the URL."
        />
        <Screenshot
          src={keyTopicsShot}
          alt="Zicy Key Topics, the topics the brand leads, the battlegrounds worth contesting and the blind spots ceded, with the competitor credited on each."
          caption="Key Topics: leaders, battlegrounds and blind spots."
        />
      </div>
    </div>
  </section>

  <!-- 5. FAQ — native <details> accordion; answers in static HTML + FAQPage schema -->
  <section style="background:var(--mist)">
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow">FAQ</span>
        <h2>Questions PR teams ask.</h2>
      </div>
      <FaqAccordion items={prFaqs} defaultOpen={0} />
      <FaqUniversal />
    </div>
  </section>

  <!-- 6. Closing band -->
  <section class="final">
    <div class="wrap">
      <h2>Prove the work moved the answer.</h2>
      <p>See what AI says about your client today, across all five engines.</p>
      <div class="hcta">
        <a class="btn btn-p" href="https://app.zicy.com/register">Try for free</a>
      </div>
    </div>
  </section>
</BaseLayout>
