---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBand from '../../components/CtaBand.astro';
import Screenshot from '../../components/Screenshot.astro';
// Anonymised screenshots cleared per the privacy gate (§1.1 of the screenshots brief).
import aiVisibilityShot from '../../assets/screenshots/anonymised/ai-visibility-dashboard.png';
import visibilityGapsShot from '../../assets/screenshots/anonymised/visibility-gaps.png';

// White-label CTA destination — preserved from the existing icps.ts agencies.band.ctaHref.
const WHITELABEL_HREF = '/pricing';
const WHITELABEL_LABEL = 'Talk to us about white-label';

const title = "Zicy for agencies — white-label AI visibility, audited, fixed and proven";
const description =
  "Add AI visibility to your service line. Audit a client, fix what's broken, and prove the result — white-labelled under your brand. Zicy for marketing, creative and media agencies.";

// Single sourced stat — brief explicitly forbids fabricating a second.
const stat = {
  n: '$300M+',
  label:
    'raised by the AI-visibility tools market between mid-2025 and spring 2026 — the category is forming now; the service line is open now.',
  source: 'Surmado, 2026',
};
// Framing line displayed below the stat (NOT a stat — no number, no source).
const framing =
  "The category's weakness is your opening: most tools measure but never act. Walk into the room with the client's real AI visibility and the fixes — not a generic deck.";

const usps = [
  {
    h: 'A New Revenue Line, No Build Cost.',
    p: 'The platform and the methodology already exist. Productise AI visibility as a retainer or a one-off audit under your own brand.',
  },
  {
    h: 'Measure and Remediate in One Place.',
    p: 'The audit, the prioritised fix list, and the schema / llms.txt / content tooling to close it — so you deliver outcomes, not observations.',
  },
  {
    h: 'Win the Pitch With Truth.',
    p: "Show a prospect exactly how AI describes them today, where it's wrong, and your plan to fix it — before you've signed anything.",
  },
];

const wiifm = [
  'Open a high-margin service line without hiring a specialist team or building tech.',
  'Walk into pitches with a live, client-specific AI visibility read.',
  'White-label dashboards and deliverables — your brand on every screen.',
  "Retain clients with a recurring metric they’ll want reported every month.",
];

const modules = [
  {
    name: 'AI Visibility + Competitive AI Performance',
    desc: 'A clear scoreboard you can put in front of any client.',
  },
  {
    name: 'Visibility Gaps + Action Center',
    desc: 'The prioritised fix list, plus the schema, llms.txt and content tooling to close it.',
  },
  {
    name: 'White-Label Reporting',
    desc: 'Your brand on the dashboard and the deliverables.',
  },
  {
    name: 'Multi-Brand Management',
    desc: 'Run your whole client roster from one place (Scale plan).',
  },
];
---
<BaseLayout title={title} description={description}>
  <!-- 1. Hero (white) -->
  <section class="hero inner">
    <div class="wrap">
      <span class="eyebrow">For marketing &amp; creative agencies</span>
      <h1>AI Visibility &mdash; Audited, Fixed and Proven. Under Your Brand.</h1>
      <p class="lead">
        AEO/GEO is the brief no one on the roster owns yet. Add a new, defensible service line:
        audit a client&rsquo;s AI visibility, fix what&rsquo;s broken, and prove the result &mdash;
        white-labelled, with no platform to build.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary btn-lg" href={WHITELABEL_HREF}>{WHITELABEL_LABEL}</a>
      </div>
    </div>
  </section>

  <!-- 2. The opportunity (white) — one sourced stat + one framing line -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow">The opportunity</span>
        <h2>Your Clients Are Already Asking About AI Search. Have the Answer.</h2>
        <p>Your clients are already asking about AI search. The agency that answers first owns the budget.</p>
      </div>
      <div style="max-width:680px;margin:0 auto 18px">
        <div class="metric" style="padding:30px 32px">
          <div class="n">{stat.n}</div>
          <div class="l" style="margin-top:10px;font-size:14.5px">{stat.label}</div>
          <div class="mono" style="font-size:12px;color:var(--muted);margin-top:12px;letter-spacing:.02em">
            Source: {stat.source}
          </div>
        </div>
      </div>
      <p class="lead" style="font-size:17px;max-width:760px;margin:18px auto 0">{framing}</p>
    </div>
  </section>

  <!-- 3. Why Zicy (lavender) — three USP cards -->
  <section style="background:var(--lavender)">
    <div class="wrap">
      <div class="shead"><h2>Why Agencies Choose Zicy.</h2></div>
      <div class="grid-3">
        {usps.map((u) => (
          <div class="card"><h3>{u.h}</h3><p>{u.p}</p></div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. What you get (white) — four-item benefit list -->
  <section>
    <div class="wrap">
      <div class="shead"><h2>What You Get.</h2></div>
      <ul class="checklist">
        {wiifm.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <!-- 5. Inside the platform (lavender) — four module cards + two product shots -->
  <section style="background:var(--lavender)">
    <div class="wrap">
      <div class="shead"><h2>Inside the Platform.</h2></div>
      <div class="grid-2">
        {modules.map((m) => (
          <div class="card">
            <span class="eyebrow">Module</span>
            <h3>{m.name}</h3>
            <p>{m.desc}</p>
          </div>
        ))}
      </div>
      <div class="grid-2" style="margin-top:28px">
        <Screenshot
          src={aiVisibilityShot}
          alt="Zicy AI Visibility dashboard a client can be shown — coverage, share of voice and ranking across AI engines."
          caption="AI Visibility &mdash; the scoreboard you put in front of any client."
        />
        <Screenshot
          src={visibilityGapsShot}
          alt="Zicy Visibility Gaps showing prioritised technical fixes, content optimisation and new-content opportunities."
          caption="Visibility Gaps + Action Center &mdash; the prioritised fix list, ready to ship."
        />
      </div>
    </div>
  </section>

  <!-- 6. Proof (white) — two numbers + measurement disclosure (3 engines per canon) -->
  <section>
    <div class="wrap">
      <div class="shead"><h2>What It Looks Like When It Works.</h2></div>
      <div style="max-width:760px">
        <div class="metric" style="padding:32px 34px">
          <div class="n g" style="font-size:44px">
            290<span style="font-size:22px">%</span>
            <span style="display:inline-block;width:18px"></span>
            <span style="color:var(--indigo)">18.11<span style="font-size:22px">%</span></span>
          </div>
          <div class="l" style="margin-top:14px;font-size:14px">
            <b style="color:var(--green)">290%</b> more AI-search clicks &middot;
            <b style="color:var(--indigo)">18.11%</b> AI share of voice &middot;
            multi-category, content-led
          </div>
        </div>
        <p class="disclosure">
          Measurement: AI brand mention and citation rates across tracked category queries on
          ChatGPT, Gemini, and Perplexity, via Zicy&rsquo;s measurement infrastructure. Client
          anonymised pending naming permission.
        </p>
      </div>
    </div>
  </section>

  <!-- 7. Closing CTA — same white-label destination as the hero CTA -->
  <CtaBand heading="Make AI Visibility Your Next Service Line." ctaLabel={WHITELABEL_LABEL} ctaHref={WHITELABEL_HREF} />
</BaseLayout>
