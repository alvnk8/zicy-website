---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Screenshot from '../../components/Screenshot.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import FaqUniversal from '../../components/FaqUniversal.astro';
import { agenciesFaqs, faqPageJsonLd } from '../../data/faqs';
// No-chrome product exports — topbar + content only, no left module-nav rail or in-frame
// Zicy logo. Demo brand "Acme Pickleball Fashion" is illustrative, not a real client.
import aiVisibilityShot from '../../assets/screenshots/ai-visibility-dashboard.png';
import competitiveShot from '../../assets/screenshots/competitive-ai-performance.png';

// White-label / agencies-plan destination. The Scale (white-label, multi-brand) tier lives on
// /pricing; there is no dedicated agency-partner signup route in the repo. Per the brief guard,
// these CTAs route to the agencies plan, NOT the generic /audit.
const PARTNER_HREF = '/pricing';
const PARTNER_LABEL = 'Become a Zicy agency partner';

const title = 'Zicy for marketing and creative agencies — productise AI visibility under your brand';
const description =
  "Walk into the room with a client's live AI visibility, not a generic deck. Measure, remediate and report AI visibility across all five engines — white-labelled, with no platform to build. Zicy for agencies.";

// §01 — the opportunity. Every figure carries publisher + year inline, verbatim. Do not alter.
const oppStats = [
  {
    n: '>US$300M',
    nStyle: '',
    label: 'raised across AI-visibility tools between mid-2025 and spring 2026.',
    source: 'Surmado, 2026',
  },
  {
    n: 'US$886M → US$7.3B',
    nStyle: 'font-size:clamp(28px,4.2vw,40px)',
    label: 'the GEO services market, 2024 to 2031 (a 34% CAGR).',
    source: 'Valuates Reports, 2025',
  },
];

// §02 — why agencies choose Zicy (three pillars).
const pillars = [
  {
    h: 'Sell the fix, not just the problem.',
    p: 'Most AI tools only measure. Zicy delivers the audit, the prioritised fix list, and the schema, llms.txt and content tooling to close it — so you bill for outcomes, not diagnoses.',
  },
  {
    h: 'Your brand on every screen.',
    p: 'Unlimited projects and brands on every plan; the Scale tier adds multi-brand management built for a portfolio, with white-label dashboards under your own name.',
  },
  {
    h: 'The endorsed side of the line.',
    p: "The tooling is aligned with Google's May 2026 spam-policy guidance — clarity, accuracy, demonstrable expertise — so what you resell protects your agency's reputation, not just the client's.",
  },
];

// §03 — what you productise (outcome bullets).
const productise = [
  'A new-business wedge: a live AI visibility audit you run on a prospect before anything is signed.',
  'A monthly retainer: AI share of voice and the fixes shipped against it, reported per client.',
  'A one-off engagement: audit, prioritised fix list, remediation.',
  'A portfolio operation: the whole roster run from one place, your brand on every report.',
];

// §04 — module touchpoints.
const modules = [
  {
    name: 'AI Visibility',
    desc: 'Mention coverage, citation rate, AI Share of Voice and average ranking, per client, against the competitors that client worries about.',
  },
  {
    name: 'Brand Intelligence',
    desc: 'How AI describes each client, the AI Reality Score, the entity gaps, and a prioritised action plan you can present.',
  },
  {
    name: 'Action Center',
    desc: 'Schema, llms.txt and content tooling built to current best practice — the remediation you bill for.',
  },
  {
    name: 'Competitive AI Performance',
    desc: "Each client's standing against rivals, the table that wins the pitch.",
  },
  {
    name: 'Multi-brand management (Scale)',
    desc: 'The roster from one place, white-labelled.',
  },
];

// §05 — FAQ, page-specific block (11) from src/data/faqs.ts; the universal block renders beneath
// it via <FaqUniversal />. JSON-LD = agencies specific + universal, matching the visible answers.
const faqPage = faqPageJsonLd(agenciesFaqs);
---
<BaseLayout title={title} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqPage)} />

  <!-- 1. Hero -->
  <section class="hero inner">
    <div class="wrap">
      <span class="eyebrow">For marketing &amp; creative agencies</span>
      <h1>Walk into the room with the client&rsquo;s live AI visibility, not a generic deck.</h1>
      <p class="lead">
        Clients are raising AI search in reviews and pitches. Zicy lets you answer first &mdash;
        show a prospect exactly how AI describes them today across all five engines (ChatGPT,
        Gemini, Perplexity, Google AI Overview and Google AI Mode), where it&rsquo;s wrong, and
        your plan to fix it, all under your own brand.
      </p>
      <div class="cta-row">
        <a class="btn btn-p btn-lg" href={PARTNER_HREF}>{PARTNER_LABEL}</a>
        <a class="btn btn-o btn-lg" href="/platform">See the platform</a>
      </div>
    </div>
  </section>

  <!-- 2. 01 · The opportunity — two sourced market stats -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">01</span> The opportunity</span>
        <h2>A service line that&rsquo;s funding and forming now.</h2>
        <p>
          AI visibility is a budget line clients are already moving money toward, and the agencies
          that productise it first take the category before it crowds.
        </p>
      </div>
      <div class="grid-2">
        {oppStats.map((s) => (
          <div class="stat">
            <div class="n" style={s.nStyle}>{s.n}</div>
            <div class="t">{s.label}</div>
            <div class="s">Source: {s.source}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. 02 · Why agencies choose Zicy — three pillars -->
  <section style="background:var(--mist)">
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">02</span> Why agencies choose Zicy</span>
        <h2>Measure and remediate in one place.</h2>
      </div>
      <div class="grid-3">
        {pillars.map((p) => (
          <div class="card"><h3>{p.h}</h3><p>{p.p}</p></div>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. 03 · What you productise — outcome bullets -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">03</span> What you productise</span>
        <h2>A repeatable service from one workflow.</h2>
      </div>
      <ul class="checklist">
        {productise.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <!-- 5. 04 · Inside the platform — five module cards + two product shots -->
  <section style="background:var(--mist)">
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">04</span> Inside the platform</span>
        <h2>The modules you resell.</h2>
      </div>
      <div class="grid-3">
        {modules.map((m) => (
          <div class="card">
            <span class="eyebrow">Module</span>
            <h3>{m.name}</h3>
            <p>{m.desc}</p>
          </div>
        ))}
      </div>
      <div class="grid-2" style="margin-top:28px">
        <Screenshot
          src={aiVisibilityShot}
          alt="Zicy AI Visibility dashboard a client can be shown — mention coverage, AI share of voice and average ranking across the engines."
          caption="AI Visibility — the scoreboard you put in front of any client."
        />
        <Screenshot
          src={competitiveShot}
          alt="Zicy Competitive AI Performance table comparing a client against rivals on mention coverage, ranking, citations, share of voice and sentiment."
          caption="Competitive AI Performance — the table that wins the pitch."
        />
      </div>
    </div>
  </section>

  <!-- 6. FAQ — native <details> accordion; answers in static HTML + FAQPage schema -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow">FAQ</span>
        <h2>Questions agencies ask.</h2>
      </div>
      <FaqAccordion items={agenciesFaqs} defaultOpen={0} />
      <FaqUniversal />
    </div>
  </section>

  <!-- 7. Closing band -->
  <section class="final">
    <div class="wrap">
      <h2>Productise the answer before your competitors do.</h2>
      <p>Add AI visibility as a white-label service line — the platform and methodology already exist.</p>
      <div class="hcta">
        <a class="btn btn-p" href={PARTNER_HREF}>{PARTNER_LABEL}</a>
        <a class="btn btn-o" href="/platform">See the platform</a>
      </div>
    </div>
  </section>
</BaseLayout>
