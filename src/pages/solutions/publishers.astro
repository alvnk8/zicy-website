---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SegmentSchema from '../../components/SegmentSchema.astro';
import Screenshot from '../../components/Screenshot.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import FaqUniversal from '../../components/FaqUniversal.astro';
import { publishersFaqs, faqPageJsonLd } from '../../data/faqs';
// No-chrome product exports — topbar + content only, no left module-nav rail or in-frame
// Zicy logo. Demo brand "Acme Pickleball Fashion" is illustrative, not a real client.
// citation-analysis-urls.png carries CLEAN labels (owned / earned / competitor / uncited;
// "paraphrased, no credit") — NOT the overview export, whose tiles bake in banned terms.
import aiVisibilityShot from '../../assets/screenshots/publishers-ai-visibility.png';
import citationUrlsShot from '../../assets/screenshots/publishers-citation-analysis.png';
import siteTrafficShot from '../../assets/screenshots/publishers-site-traffic.png';

const title = 'Zicy for publishers: sell advertising as measurable AI-visibility uplift';
const description =
  "Sell media to brands as measurable AI-visibility uplift, not just impressions: prove a campaign lifted an advertiser's branded search and their visibility across ChatGPT, Gemini, Perplexity, Google AI Overviews and Google AI Mode, and see whether AI credits your own journalism.";

// §01 — the commercial shift. Every figure carries publisher + year inline, verbatim. Do not alter.
const shiftStats = [
  {
    n: '≈0.66',
    label:
      "web mentions are the single strongest predictor of a brand's AI citation, roughly three times backlinks, and advertising and editorial are how they get created.",
    source: 'Digital Bloom, 2026',
  },
  {
    n: '~83%',
    label: "of a brand's market share is reflected in its share of search, the metric advertising moves.",
    source: 'Binet & Field / IPA, 2020',
  },
];

// §03 — what you can prove (capability framing only; no delivered-uplift numbers).
const proofBullets = [
  "A pre-campaign baseline of the advertiser's AI Share of Voice and branded search.",
  'Continuous tracking across the campaign window.',
  'A post-campaign read your sales team can put in a renewal conversation.',
];

// §04 — defend your journalism (attribution stakes).
const attributionStats = [
  {
    n: '~1%',
    label: "click-through to an AI Overview's own citation links when present.",
    source: 'Pew Research, 2025',
  },
  {
    n: 'Three years',
    nStyle: 'font-size:clamp(34px,4.5vw,48px)',
    label: 'the horizon over which news leaders expect to lose significant search-referral traffic.',
    source: 'Reuters Institute, Trends and Predictions 2026',
  },
];

// §05 — module touchpoints, grouped by the two motions (group used as the card eyebrow).
const modules = [
  {
    group: 'Media sales',
    name: 'AI Visibility',
    desc: "An advertiser's mention coverage, citation rate, AI Share of Voice and average ranking across five engines, baselined and tracked across a campaign.",
  },
  {
    group: 'Media sales',
    name: 'Competitive AI Performance',
    desc: "The advertiser's standing vs rivals, the before-and-after your sales team shows.",
  },
  {
    group: 'Media sales',
    name: 'Site Traffic / share of search',
    desc: 'Branded-search movement from public search data, the first link in the chain made visible.',
  },
  {
    group: 'Your journalism',
    name: 'Citation Analysis',
    desc: 'Attribution, paraphrase-without-credit and the uncited rate, down to domain and URL.',
  },
  {
    group: 'Your journalism',
    name: 'Site Audit',
    desc: 'llms.txt, bot access, schema and page health; scales to large archives via audit-boost add-ons.',
  },
  {
    group: 'Your journalism',
    name: 'Key Topics Analysis',
    desc: 'Leaders, Battlegrounds and Blind Spots against competing outlets.',
  },
];

// §06 — FAQ. Page-specific block (14, media-sales motion leading then attribution/licensing)
// from src/data/faqs.ts; the universal block renders beneath it via <FaqUniversal />. JSON-LD =
// publishers specific + universal, matching the visible answers. The rel="sponsored"/nofollow +
// disclosure language and the "measured correlation, not a guaranteed citation" line live in
// publishersFaqs Q4 and are load-bearing — do not soften.
//
// TODO(faq-doc): the media-sales Q&As ("We sell advertising — how does Zicy help us sell more of
// it?" and "Are we promising advertisers that paying us gets them cited by AI?") originate on
// this page; add them to the canonical Zicy ICP FAQ doc.
const faqPage = {
  ...faqPageJsonLd(publishersFaqs),
  speakable: { '@type': 'SpeakableSpecification', cssSelector: ['#at-a-glance'] },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.zicy.com/' },
    { '@type': 'ListItem', position: 2, name: 'For publishers', item: 'https://www.zicy.com/solutions/publishers' },
  ],
};
---
<BaseLayout title={title} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumb)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqPage)} />
  <SegmentSchema slot="head" url="https://www.zicy.com/solutions/publishers" name={title} audienceType="publisher" />

  <!-- 1. Hero — leads with the media-sales motion -->
  <section class="hero inner">
    <div class="wrap">
      <span class="eyebrow">For publishers</span>
      <h1>Sell advertising as measurable AI-visibility uplift, not just impressions.</h1>
      <p class="lead">
        Publishers sell media to brands. Zicy lets you sell it as something an advertiser
        can&rsquo;t get from a rate card alone: proof that a campaign with you lifted their
        branded search and their visibility across ChatGPT, Gemini, Perplexity, Google AI Overviews
        and Google AI Mode. And it shows whether AI credits your own journalism, too.
      </p>
      <div class="cta-row">
        <a class="btn btn-p btn-lg" href="https://app.zicy.com/register">Try for free</a>
        <a class="btn btn-o btn-lg" href="/platform">See the platform</a>
      </div>
    </div>
  </section>

  <!-- At a glance — semantic summary directly below the hero, above the first body section.
       Reuses .shead (heading) and .checklist (list); body text is full-strength --ink (AA on
       paper) and the list marker uses --ok, never the Sky token. No numerals in the copy. -->
  <section id="at-a-glance">
    <div class="wrap">
      <div class="shead">
        <h2>At a glance</h2>
      </div>
      <ul class="checklist">
        <li>Zicy shows publishers which of their pages AI answer engines cite, and for which topics and queries.</li>
        <li>It tracks citations at the URL level across ChatGPT, Gemini, Perplexity, Google AI Overviews, and Google AI Mode.</li>
        <li>Publishers can see where they are already the cited source and where high-value topics are still open.</li>
      </ul>
    </div>
  </section>

  <!-- 2. 01 · The commercial shift — two sourced stats -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">01</span> The commercial shift</span>
        <h2>Two things changed for your business at once.</h2>
        <p>
          Advertisers want outcomes beyond impressions, and AI answers increasingly decide which
          brands buyers consider. That makes AI visibility a thing you can now sell, and
          prove, on top of the inventory you already have.
        </p>
      </div>
      <div class="grid-2">
        {shiftStats.map((s) => (
          <div class="stat">
            <div class="n">{s.n}</div>
            <div class="t">{s.label}</div>
            <div class="s">Source: {s.source}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. 02 · The mechanism — sourced and honest; the policy-guard line is verbatim -->
  <section style="background:var(--mist)">
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">02</span> Why advertising with you lifts AI visibility</span>
        <h2>The chain, stated plainly.</h2>
      </div>
      <div style="max-width:760px">
        <p class="sub" style="font-size:17px">
          The advertising you sell builds an advertiser&rsquo;s brand demand, and that shows up
          first as branded search. Advertising share of voice is a primary driver of share of
          search (Binet &amp; Field / IPA, 2020), confirmed by controlled lift studies that measure
          incremental branded search from ad exposure (Google Search Lift).
        </p>
        <p class="sub" style="font-size:17px;margin-top:18px">
          Here is the part that matters for AI: the engines don&rsquo;t read the ad. They read the
          behavioural signals it creates. Branded search correlates with AI visibility at roughly
          0.33&ndash;0.39 (Growth Memo, Kevin Indig, 2025), and web mentions are the single
          strongest predictor at about 0.66, roughly three times backlinks (Digital Bloom, 2026).
          Display advertising has been shown to influence generative-search citations through
          exactly these signals rather than the ad itself (Brafton, 2026).
        </p>
        <p class="sub" style="font-size:17px;margin-top:18px">
          So a campaign with you is not just impressions; it moves the signals AI weights when it
          names brands. And your editorial is the stronger lever than display, because it creates
          the web mentions AI weights most.
        </p>
        <p class="pullquote">
          This is a measured correlation, not a guaranteed citation, and that is exactly why it is
          defensible.
        </p>
      </div>
    </div>
  </section>

  <!-- 4. 03 · What you can prove — proof/measurement section + Site Traffic screenshot -->
  <section>
    <div class="wrap">
      <div class="feature-split">
        <div class="shead" style="margin-bottom:0">
          <span class="eyebrow"><span class="ix">03</span> What you can prove</span>
          <h2>Bring the proof to the rate-card conversation.</h2>
          <p>
            Zicy tracks any advertiser&rsquo;s AI visibility across all five engines and their share
            of search from public search data (no access to the advertiser&rsquo;s analytics
            required), so your sales team can show a before-and-after around a campaign window.
            You sell the inventory; Zicy gives you the evidence that it moved the advertiser&rsquo;s
            position in the answer.
          </p>
          <ul class="checklist" style="margin-top:20px">
            {proofBullets.map((b) => <li>{b}</li>)}
          </ul>
        </div>
        <Screenshot
          src={siteTrafficShot}
          alt="Zicy Site Traffic, Search Console view: an advertiser's share of search and branded-search behaviour from public search data, tracked across a campaign window."
          caption="Site Traffic: branded-search movement from public search data, baselined and tracked."
        />
      </div>
    </div>
  </section>

  <!-- 5. 04 · Defend your own journalism — secondary, condensed + two attribution stats -->
  <section style="background:var(--mist)">
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">04</span> Defend your own journalism</span>
        <h2>And know whether AI credits your work.</h2>
        <p>
          The same platform shows whether AI attributes your journalism, paraphrases it without
          credit, or ignores it, across five engines, down to the URL. A documented uncited
          rate and source-level attribution give your commercial team an evidence base for
          AI-licensing conversations, at a moment when publishers from the Associated Press to USA
          Today are signing AI content deals while others litigate over uncited use (Digiday; Press
          Gazette, 2025&ndash;26).
        </p>
      </div>
      <div class="grid-2">
        {attributionStats.map((s) => (
          <div class="stat">
            <div class="n" style={s.nStyle ?? ''}>{s.n}</div>
            <div class="t">{s.label}</div>
            <div class="s">Source: {s.source}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. 05 · Inside the platform — six module cards (grouped by motion) + two product shots -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow"><span class="ix">05</span> Inside the platform</span>
        <h2>The modules behind both motions.</h2>
      </div>
      <div class="grid-3">
        {modules.map((m) => (
          <div class="card">
            <span class="eyebrow">{m.group}</span>
            <h3>{m.name}</h3>
            <p>{m.desc}</p>
          </div>
        ))}
      </div>
      <div class="grid-2" style="margin-top:28px">
        <Screenshot
          src={aiVisibilityShot}
          alt="Zicy AI Visibility dashboard: an advertiser's mention coverage, citation rate, AI share of voice and average ranking across the engines, ready to baseline against a campaign."
          caption="AI Visibility: baseline an advertiser, track the campaign window."
        />
        <Screenshot
          src={citationUrlsShot}
          alt="Zicy Citation Analysis: the domains and individual URLs AI cites, classified owned, earned, competitor or uncited, for your own journalism."
          caption="Citation Analysis: attribution and the uncited rate, down to the URL."
        />
      </div>
    </div>
  </section>

  <!-- 7. FAQ — native <details> accordion; answers in static HTML + FAQPage schema -->
  <section style="background:var(--mist)">
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow">FAQ</span>
        <h2>Questions publishers ask.</h2>
      </div>
      <FaqAccordion items={publishersFaqs} defaultOpen={0} />
      <FaqUniversal />
    </div>
  </section>

  <!-- 8. Closing band -->
  <section class="final">
    <div class="wrap">
      <h2>Sell the answer, and prove you moved it.</h2>
      <p>Baseline an advertiser, or see whether AI credits your journalism, across all five engines.</p>
      <div class="hcta">
        <a class="btn btn-p" href="https://app.zicy.com/register">Try for free</a>
        <a class="btn btn-o" href="/platform">See the platform</a>
      </div>
    </div>
  </section>
</BaseLayout>
