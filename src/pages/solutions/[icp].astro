---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBand from '../../components/CtaBand.astro';
import Screenshot from '../../components/Screenshot.astro';
import { ICPS } from '../../data/icps';

export function getStaticPaths() {
  // Every ICP now has its own richer static page at a sibling .astro file —
  // exclude all four here so the build does not generate duplicate routes.
  // The dynamic [icp].astro template currently has no consumers; it is kept as a
  // scaffold in case a future ICP slug is added before its dedicated page exists.
  const STATIC_OVERRIDES = new Set(['brands', 'pr', 'agencies', 'publishers']);
  return ICPS
    .filter((icp) => !STATIC_OVERRIDES.has(icp.slug))
    .map((icp) => ({ params: { icp: icp.slug }, props: { icp } }));
}

const { icp } = Astro.props;
---
<BaseLayout title={icp.metaTitle} description={icp.metaDescription}>
  <!-- Hero -->
  <section class="hero inner">
    <div class="wrap">
      <span class="eyebrow">{icp.eyebrow}</span>
      <h1>{icp.h1}</h1>
      <p class="lead">{icp.heroSub}</p>
      <div class="cta-row">
        <a class="btn btn-primary btn-lg" href={icp.heroCta.href}>{icp.heroCta.label}</a>
      </div>
    </div>
  </section>

  <!-- The risk / opportunity + hero modules + screenshots -->
  <section>
    <div class="wrap">
      <div class="shead">
        <span class="eyebrow">{icp.sectionEyebrow}</span>
        <h2>{icp.sectionH2}</h2>
        <p>{icp.sectionSub}</p>
      </div>
      <div class="grid-3">
        {icp.modules.map((m) => (
          <div class="card">
            <span class="eyebrow">Module</span>
            <h3>{m.name}</h3>
            <p>{m.desc}</p>
          </div>
        ))}
      </div>
      <div class="grid-2" style="margin-top:24px">
        {icp.screenshots
          .filter((s) => s.src)
          .map((s) => <Screenshot src={s.src!} alt={s.alt!} caption={s.caption} />)}
      </div>
    </div>
  </section>

  <!-- Why this ICP chooses Zicy -->
  <section style="background:var(--lavender)">
    <div class="wrap">
      <div class="shead"><h2>{icp.whyHeading}.</h2></div>
      <div class="grid-3">
        {icp.why.map((w) => (
          <div class="card">
            <h3>{w.lead}</h3>
            <p>{w.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand heading={icp.band.heading} ctaLabel={icp.band.ctaLabel} ctaHref={icp.band.ctaHref} />
</BaseLayout>
