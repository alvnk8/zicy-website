---
// DRAFT pricing page (/pricing-v2). Unlinked and noindex until go-live; the live page at
// src/pages/pricing.astro is untouched. Every price and count comes from src/data/pricing.ts;
// nothing is hard-coded on this page.
//
// VERIFY (state at last build, do NOT action here):
//  - astro build passes; full page renders in order at /pricing-v2.
//  - noindex present; page unlinked (not in nav / footer / sitemap).
//  - src/pages/pricing.astro untouched; nothing deployed.
//
// GO-LIVE checklist (only when Alvin says, do NOT action):
//  1. Re-verify every competitor cell in the comparison table against live pages.
//  2. Remove noindex.
//  3. Add the route to nav + sitemap.
//  4. Rename to /pricing, or 308 the old route to it.
//  5. Confirm the /done-for-you handoff still carries
//     utm_source=zicy&utm_medium=referral&utm_campaign=dfy.
import BaseLayout from '../layouts/BaseLayout.astro';
import CoreTiers from '../components/pricing/CoreTiers.astro';
import AgencyBlock from '../components/pricing/AgencyBlock.astro';
import ContentModule from '../components/pricing/ContentModule.astro';
import MultiMarket from '../components/pricing/MultiMarket.astro';
import ComparisonTable from '../components/pricing/ComparisonTable.astro';
import PricingFAQ from '../components/pricing/PricingFAQ.astro';
import { CORE_TIERS, AGENCY_TIERS, PRICING_FAQS } from '../data/pricing';
import { SITE } from '../data/site';

const title = 'Zicy pricing, all five AI engines on every plan';
const description =
  'All five AI engines, every plan. No per-engine add-ons. Scale from Starter to Enterprise, plus an agency track with pooled prompts.';

// Offer schema: one Product node listing the four core plus two agency tiers as Offers. Tiers with a
// fixed monthly price carry price + priceCurrency; Enterprise and the agency tiers are contact-only
// Offers with a sales URL and no fixed price. isRelatedTo points at the sitewide SoftwareApplication
// (@id from Schema.astro) instead of duplicating it. No aggregateRating, no review.
const pageUrl = `${SITE.url}/pricing-v2`;
const toOffer = (t: (typeof CORE_TIERS)[number]) =>
  t.priceMonthly !== null
    ? { '@type': 'Offer', name: t.name, price: String(t.priceMonthly), priceCurrency: 'USD', url: pageUrl }
    : { '@type': 'Offer', name: t.name, priceCurrency: 'USD', url: t.cta.href, availability: 'https://schema.org/InStock' };
const offerSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Zicy plans',
  description:
    'Zicy pricing plans. All five AI engines on every plan, with no per-engine add-ons.',
  brand: { '@type': 'Organization', name: SITE.name },
  isRelatedTo: { '@id': `${SITE.url}/#app` },
  offers: [...CORE_TIERS, ...AGENCY_TIERS].map(toOffer),
};

// FAQPage from the same array the visible accordion renders, so the text mirrors it verbatim.
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: PRICING_FAQS.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<BaseLayout title={title} description={description} noindex={true}>
  <!-- 1. Hero -->
  <section class="hero inner">
    <div class="wrap">
      <span class="eyebrow">Pricing</span>
      <h1>All five AI engines, every plan.<br />No per-engine add-ons.</h1>
      <p class="lead">Be the brand AI gets right, on every engine, without paying extra to see them all.</p>
      <p class="hengines">Every plan tracks ChatGPT, Gemini, Perplexity, Google AI Overviews and Google AI Mode.</p>
      <p class="hmicro mono">
        One tracked prompt is measured across all five engines every day, so 50 prompts is up to
        7,500 AI answers a month.
      </p>
    </div>
  </section>

  <!-- 2. Core ladder + annual toggle -->
  <CoreTiers />

  <!-- 3. Agency track -->
  <AgencyBlock />

  <!-- 4. Anchors for later parts (Part 3 owns FAQ + schema) -->
  <!--SLOT:content-module--><ContentModule />
  <!--SLOT:multi-market--><MultiMarket />
  <!--SLOT:comparison--><ComparisonTable />
  <!--SLOT:faq--><PricingFAQ />
  <!--SLOT:schema-->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(offerSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />
</BaseLayout>

<style>
  .hengines{font-size:15px;color:var(--ink);font-weight:500;margin-top:16px;max-width:60ch;line-height:1.6}
  .hmicro{font-size:13px;color:var(--muted);margin-top:16px;max-width:60ch;line-height:1.7}
</style>
